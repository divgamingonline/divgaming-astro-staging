---
import Icon from './Icon.astro';
import type { DiscoveryFilter } from '../utils/builds';

export interface Props {
  count: number;
  filters?: DiscoveryFilter[];
  label?: string;
  placeholder?: string;
}

const {
  count,
  filters = [],
  label = 'Search SHD intel',
  placeholder = 'Search builds, creators, tags, activities...'
} = Astro.props;
---

<div class="discovery-controls card" data-discovery-controls>
  <div class="discovery-controls__top">
    <label class="discovery-search">
      <span>{label}</span>
      <input type="search" placeholder={placeholder} data-discovery-search />
    </label>

    <div class="discovery-count">
      <strong data-result-count>{count}</strong>
      <span>visible</span>
    </div>
  </div>

  <div class="discovery-filter-toolbar">
    {filters.length > 0 && (
      <button type="button" class="filter-toggle" data-discovery-filter-toggle aria-expanded="false">
        <Icon name="list-filter" />
        Filters
      </button>
    )}
    <button type="button" class="discovery-reset" data-discovery-reset>Reset</button>
  </div>

  {filters.length > 0 && (
    <div class="discovery-filters" aria-label="Discovery filters" data-discovery-filter-panel>
      <button type="button" class="active" data-discovery-filter="all">All</button>
      {filters.map((filter) => (
        <button type="button" data-discovery-filter={filter.value}>{filter.label}</button>
      ))}
    </div>
  )}
</div>

<script>
  function initDiscoveryControls(scope) {
    const searchInput = scope.querySelector('[data-discovery-search]');
    const cards = [...document.querySelectorAll('[data-discovery-card]')];
    const filterButtons = [...scope.querySelectorAll('[data-discovery-filter]')];
    const count = scope.querySelector('[data-result-count]');
    const reset = scope.querySelector('[data-discovery-reset]');
    const emptyState = document.querySelector('[data-discovery-empty]');
    const filterToggle = scope.querySelector('[data-discovery-filter-toggle]');
    let activeFilter = 'all';

    function closeFiltersOnMobile() {
      if (window.matchMedia('(max-width: 780px)').matches) {
        scope.classList.remove('filters-open');
        filterToggle?.setAttribute('aria-expanded', 'false');
      }
    }

    function applyFilters() {
      const query = (searchInput?.value || '').trim().toLowerCase();
      let visible = 0;

      for (const card of cards) {
        const search = card.dataset.search || '';
        const filters = (card.dataset.filters || '').split(' ');
        const matchesSearch = !query || search.includes(query);
        const matchesFilter = activeFilter === 'all' || filters.includes(activeFilter);
        const shouldShow = matchesSearch && matchesFilter;

        card.hidden = !shouldShow;
        if (shouldShow) visible += 1;
      }

      if (count) count.textContent = String(visible);
      if (emptyState) emptyState.hidden = visible !== 0;
    }

    filterToggle?.addEventListener('click', () => {
      const isOpen = scope.classList.toggle('filters-open');
      filterToggle.setAttribute('aria-expanded', String(isOpen));
    });

    searchInput?.addEventListener('input', applyFilters);

    for (const button of filterButtons) {
      button.addEventListener('click', () => {
        activeFilter = button.dataset.discoveryFilter || 'all';

        for (const item of filterButtons) {
          item.classList.toggle('active', item === button);
        }

        applyFilters();
        closeFiltersOnMobile();
      });
    }

    reset?.addEventListener('click', () => {
      if (searchInput) searchInput.value = '';
      activeFilter = 'all';

      for (const button of filterButtons) {
        button.classList.toggle('active', button.dataset.discoveryFilter === 'all');
      }

      applyFilters();
      closeFiltersOnMobile();
    });

    applyFilters();
  }

  for (const scope of document.querySelectorAll('[data-discovery-controls]')) {
    initDiscoveryControls(scope);
  }
</script>
