---
import Icon from './Icon.astro';
export interface Props { videos?: number; creators?: number; records?: number; }
const { videos = 0, creators = 0, records = 0 } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const withBase = (href: string) => href.startsWith('http') ? href : `${base}${href}`;
const coffeeUrl = 'https://buymeacoffee.com/divgamingoy';

const socials = [
  ['Discord', '/assets/img/socials/discord.png', '#'],
  ['YouTube', '/assets/img/socials/youtube.png', '#'],
  ['Twitch', '/assets/img/socials/twitch.png', '#'],
  ['TikTok', '/assets/img/socials/tiktok.png', '#'],
  ['Instagram', '/assets/img/socials/instagram.png', '#'],
  ['X', '/assets/img/socials/x.png', '#']
];

const status = [
  ['Current Focus', 'Production parity', 'The Astro reset is focused on matching production first, then improving features.'],
  ['Creator Traffic', 'YouTube direct', 'Videos are indexed for discovery and open on the creator’s channel.'],
  ['Data Layer', 'JSON driven', 'Builds, tools, gear, talents, and videos are powered by maintainable data files.'],
  ['Cutover Status', 'Not yet', 'The live site stays untouched until staging passes review.']
];
---

<footer class="site-footer">
  <div class="shell footer-grid">
    <div>
      <div class="footer-brand">
        <img src={withBase('/assets/img/dg-logo.png')} alt="DivGaming logo" />
        <strong>DivGaming.com</strong>
      </div>
      <p class="footer-tagline">
        A Division 2 community hub for builds, gear tools, creator videos, guides,
        maps, vendor resources, and player-friendly reference material.
      </p>

      <div class="footer-stats">
        <div><strong>{videos}</strong><span>Videos Indexed</span></div>
        <div><strong>{creators}</strong><span>Creators Listed</span></div>
        <div><strong>{records}</strong><span>Tool Records</span></div>
        <div><strong>Active</strong><span>Staging Review</span></div>
      </div>

      <p class="footer-small">
        DivGaming.com is an independent community project and is not affiliated with Ubisoft,
        Massive Entertainment, or The Division franchise.
      </p>
      <p class="footer-small">© 2026 DivGaming.com. Built for the Division community by ItsSandman.</p>
    </div>

    <div class="footer-actions">
      <section class="footer-card">
        <p class="eyebrow">Connect</p>
        <h3>Follow DivGaming</h3>
        <div class="social-links">
          {socials.map(([label, icon, href]) => (
            <a href={href} aria-label={label}><img src={withBase(icon)} alt="" /></a>
          ))}
        </div>
      </section>

      <section class="footer-card support-card">
        <p class="eyebrow">Support the project</p>
        <h3>Keep DivGaming useful</h3>
        <p>Support helps with tool updates, build tracking, creator indexing, and future features.</p>
        <a class="button primary" href={coffeeUrl} target="_blank" rel="noopener">
          <Icon name="coffee" />
          Contribute Resources
        </a>
      </section>

      <a class="back-top" href="#top">Back to top ↑</a>
    </div>
  </div>

  <section class="shell launch-band">
    <div class="launch-band-head">
      <div>
        <p class="eyebrow">Launch Status</p>
        <h3>Astro production-parity reset</h3>
        <p>This version is intentionally conservative: match production, stabilize pages, then improve features.</p>
      </div>
      <div class="launch-actions">
        <a href={withBase('/division-2/')}>Review Hub</a>
        <a href={withBase('/division-2/tools/')}>Check Tools</a>
      </div>
    </div>

    <div class="launch-items">
      {status.map(([label, value, text]) => (
        <article>
          <span>{label}</span>
          <strong>{value}</strong>
          <p>{text}</p>
        </article>
      ))}
    </div>
  </section>
</footer>
