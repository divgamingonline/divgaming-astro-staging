---
import BaseLayout from '../layouts/BaseLayout.astro';
import ToolItemCard from './ToolItemCard.astro';
import {
  countNeedsVerification,
  datasetUpdatedLabel,
  normalizeItems,
  sortByName,
  type ToolDataItem
} from '../utils/division2Tools';

export interface Props {
  title: string;
  eyebrow: string;
  description: string;
  canonical: string;
  dataset: unknown;
  featuredItems?: ToolDataItem[];
  emptyMessage?: string;
}

const {
  title,
  eyebrow,
  description,
  canonical,
  dataset,
  featuredItems = [],
  emptyMessage = 'No items found in this dataset yet.'
} = Astro.props;

const items = sortByName(normalizeItems(dataset));
const updated = datasetUpdatedLabel(dataset);
const needsVerification = countNeedsVerification(items);

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout
  title={`${title} | DivGaming Astro Staging`}
  description={description}
  canonical={canonical}
  noindex={true}
>
  <section class="shell tools-hero">
    <div class="tools-hero__content">
      <p class="eyebrow">{eyebrow}</p>
      <h1>{title}</h1>
      <p class="lead">{description}</p>
      <div class="tools-hero__actions">
        <a class="button" href={`${base}/division-2/tools/`}>All tools</a>
        <a class="button button--ghost" href={`${base}/division-2/`}>Division 2 hub</a>
      </div>
    </div>

    <aside class="tools-hero__panel card">
      <p class="eyebrow">Dataset</p>
      <h2>{items.length}</h2>
      <p>records loaded from the Astro data layer.</p>
      {updated && <p class="tools-hero__updated">Updated: {updated}</p>}
      {needsVerification > 0 && (
        <p class="tools-hero__updated">{needsVerification} records marked for verification.</p>
      )}
    </aside>
  </section>

  {featuredItems.length > 0 && (
    <section class="shell section">
      <p class="eyebrow">Featured references</p>
      <div class="grid featured-grid">
        {featuredItems.slice(0, 3).map((item) => (
          <ToolItemCard item={item} compact={true} />
        ))}
      </div>
    </section>
  )}

  <section class="shell section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Reference database</p>
        <h2>{items.length} entries</h2>
      </div>
      <p>
        This is an Astro staging version of the DivGaming tool database. Search
        and advanced filtering will come in a later phase.
      </p>
    </div>

    {items.length > 0 ? (
      <div class="grid tool-grid">
        {items.map((item) => (
          <ToolItemCard item={item} />
        ))}
      </div>
    ) : (
      <div class="card empty-state">
        <h2>{emptyMessage}</h2>
      </div>
    )}
  </section>

  <style>
    .tools-hero {
      display: grid;
      grid-template-columns: minmax(0, 1.35fr) minmax(260px, 0.65fr);
      gap: 20px;
      padding-top: 40px;
      align-items: stretch;
    }

    .tools-hero__content {
      border: 1px solid rgba(255, 107, 0, 0.16);
      border-radius: 28px;
      padding: clamp(24px, 5vw, 54px);
      background:
        radial-gradient(circle at top left, rgba(255, 107, 0, 0.24), transparent 42%),
        linear-gradient(140deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.025));
      box-shadow: var(--dg-shadow);
    }

    .tools-hero h1 {
      margin: 0;
      font-size: clamp(2.45rem, 7vw, 5.4rem);
      line-height: 0.92;
      letter-spacing: -0.065em;
      text-transform: uppercase;
    }

    .tools-hero__actions {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      margin-top: 24px;
    }

    .tools-hero__panel {
      padding: 22px;
    }

    .tools-hero__panel h2 {
      margin: 0;
      color: var(--dg-orange);
      font-size: clamp(3rem, 9vw, 6rem);
      line-height: 0.9;
      letter-spacing: -0.065em;
    }

    .tools-hero__panel p {
      color: var(--dg-muted);
    }

    .tools-hero__updated {
      border-top: 1px solid rgba(255, 255, 255, 0.08);
      padding-top: 12px;
      font-size: 0.88rem;
    }

    .featured-grid {
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    }

    .section-heading {
      display: flex;
      justify-content: space-between;
      gap: 20px;
      align-items: end;
      margin-bottom: 20px;
    }

    .section-heading h2 {
      margin: 0;
      font-size: clamp(1.9rem, 4vw, 3.2rem);
      letter-spacing: -0.045em;
    }

    .section-heading > p {
      max-width: 560px;
      margin: 0;
      color: var(--dg-muted);
    }

    .tool-grid {
      grid-template-columns: repeat(auto-fill, minmax(315px, 1fr));
      align-items: stretch;
    }

    .empty-state {
      padding: 22px;
    }

    @media (max-width: 900px) {
      .tools-hero,
      .section-heading {
        display: grid;
        grid-template-columns: 1fr;
      }

      .tools-hero {
        padding-top: 24px;
      }

      .section-heading {
        align-items: start;
      }
    }
  </style>
</BaseLayout>
