---
import BaseLayout from '../layouts/BaseLayout.astro';
import ToolItemCard from './ToolItemCard.astro';
import Icon from './Icon.astro';
import {
  buildFilterOptions,
  countNeedsVerification,
  datasetUpdatedLabel,
  normalizeItems,
  sortByName,
  type ToolDataItem
} from '../utils/division2Tools';

export interface Props {
  title: string;
  eyebrow: string;
  description: string;
  canonical: string;
  dataset: unknown;
  featuredItems?: ToolDataItem[];
  emptyMessage?: string;
}

const {
  title,
  eyebrow,
  description,
  canonical,
  dataset,
  featuredItems = [],
  emptyMessage = 'No items found in this dataset yet.'
} = Astro.props;

const items = sortByName(normalizeItems(dataset));
const filters = buildFilterOptions(items);
const updated = datasetUpdatedLabel(dataset);
const needsVerification = countNeedsVerification(items);

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const databaseId = `tool-db-${title.toLowerCase().replace(/[^a-z0-9]+/g, '-')}`;
---

<BaseLayout
  title={`${title} | DivGaming`}
  description={description}
  canonical={canonical}
  noindex={true}
>
  <section class="shell hero">
    <div class="command-hero">
      <div>
        <p class="eyebrow">{eyebrow}</p>
        <h1>{title}</h1>
        <p class="lead">{description}</p>
        <div class="hero-actions">
          <a class="btn primary" href={`${base}/division-2/tools/`}>All tools</a>
          <a class="btn ghost" href={`${base}/division-2/`}>Division 2 hub</a>
        </div>
      </div>

      <aside class="command-panel">
        <p class="eyebrow">Dataset</p>
        <div class="command-panel__list">
          <div class="command-panel__row"><span>Records</span><strong>{items.length}</strong></div>
          {updated && <div class="command-panel__row"><span>Updated</span><strong>{updated}</strong></div>}
          {needsVerification > 0 && <div class="command-panel__row"><span>Needs check</span><strong>{needsVerification}</strong></div>}
        </div>
      </aside>
    </div>
  </section>

  {featuredItems.length > 0 && (
    <section class="shell section">
      <p class="eyebrow">Featured references</p>
      <div class="grid tools-grid">
        {featuredItems.slice(0, 3).map((item) => (
          <ToolItemCard item={item} compact={true} />
        ))}
      </div>
    </section>
  )}

  <section class="shell section" id={databaseId} data-tool-database>
    <div class="section-head">
      <p class="eyebrow">Reference database</p>
      <h2><span data-result-count>{items.length}</span> entries</h2>
      <p>
        Search and filter this SHD field database by name, talent, slot, source,
        role, or keyword.
      </p>
    </div>

    <div class="tool-controls card">
      <label class="tool-search">
        <span>Search this database</span>
        <input
          type="search"
          placeholder="Search names, talents, slots, sources..."
          data-tool-search
        />
      </label>

      <div class="tool-filter-toolbar">
        {filters.length > 0 && (
          <button type="button" class="filter-toggle" data-tool-filter-toggle aria-expanded="false">
            <Icon name="list-filter" />
            Filters
          </button>
        )}
        <button type="button" class="tool-reset" data-tool-reset>Reset</button>
      </div>

      {filters.length > 0 && (
        <div class="tool-filters" aria-label="Database filters" data-tool-filter-panel>
          <button type="button" class="active" data-tool-filter="all">All</button>
          {filters.map((filter) => (
            <button type="button" data-tool-filter={filter.value}>{filter.label}</button>
          ))}
        </div>
      )}
    </div>

    {items.length > 0 ? (
      <>
        <div class="grid tool-grid" data-tool-grid>
          {items.map((item) => (
            <ToolItemCard item={item} />
          ))}
        </div>

        <div class="card empty-state" data-empty-state hidden>
          <p class="eyebrow">No results</p>
          <h2>No matching entries found.</h2>
          <p>Try a broader SHD search term or reset the filter chips.</p>
        </div>
      </>
    ) : (
      <div class="card empty-state">
        <h2>{emptyMessage}</h2>
      </div>
    )}
  </section>

  <script>
    function initToolDatabase(database) {
      const searchInput = database.querySelector('[data-tool-search]');
      const cards = [...database.querySelectorAll('[data-tool-card]')];
      const filterButtons = [...database.querySelectorAll('[data-tool-filter]')];
      const count = database.querySelector('[data-result-count]');
      const reset = database.querySelector('[data-tool-reset]');
      const emptyState = database.querySelector('[data-empty-state]');
      const filterToggle = database.querySelector('[data-tool-filter-toggle]');
      const controls = database.querySelector('.tool-controls');
      let activeFilter = 'all';

      function closeFiltersOnMobile() {
        if (window.matchMedia('(max-width: 780px)').matches) {
          controls?.classList.remove('filters-open');
          filterToggle?.setAttribute('aria-expanded', 'false');
        }
      }

      function applyFilters() {
        const query = (searchInput?.value || '').trim().toLowerCase();
        let visible = 0;

        for (const card of cards) {
          const search = card.dataset.search || '';
          const filters = (card.dataset.filters || '').split(' ');
          const matchesSearch = !query || search.includes(query);
          const matchesFilter = activeFilter === 'all' || filters.includes(activeFilter);
          const shouldShow = matchesSearch && matchesFilter;

          card.hidden = !shouldShow;
          if (shouldShow) visible += 1;
        }

        if (count) count.textContent = String(visible);
        if (emptyState) emptyState.hidden = visible !== 0;
      }

      filterToggle?.addEventListener('click', () => {
        const isOpen = controls?.classList.toggle('filters-open');
        filterToggle.setAttribute('aria-expanded', String(Boolean(isOpen)));
      });

      searchInput?.addEventListener('input', applyFilters);

      for (const button of filterButtons) {
        button.addEventListener('click', () => {
          activeFilter = button.dataset.toolFilter || 'all';

          for (const item of filterButtons) {
            item.classList.toggle('active', item === button);
          }

          applyFilters();
          closeFiltersOnMobile();
        });
      }

      reset?.addEventListener('click', () => {
        if (searchInput) searchInput.value = '';
        activeFilter = 'all';

        for (const button of filterButtons) {
          button.classList.toggle('active', button.dataset.toolFilter === 'all');
        }

        applyFilters();
        closeFiltersOnMobile();
      });

      applyFilters();
    }

    for (const database of document.querySelectorAll('[data-tool-database]')) {
      initToolDatabase(database);
    }
  </script>
</BaseLayout>
