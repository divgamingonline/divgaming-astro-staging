---
import BaseLayout from '../layouts/BaseLayout.astro';
import ToolItemCard from './ToolItemCard.astro';
import {
  buildFilterOptions,
  countNeedsVerification,
  datasetUpdatedLabel,
  normalizeItems,
  sortByName,
  type ToolDataItem
} from '../utils/division2Tools';

export interface Props {
  title: string;
  eyebrow: string;
  description: string;
  canonical: string;
  dataset: unknown;
  featuredItems?: ToolDataItem[];
  emptyMessage?: string;
}

const {
  title,
  eyebrow,
  description,
  canonical,
  dataset,
  featuredItems = [],
  emptyMessage = 'No items found in this dataset yet.'
} = Astro.props;

const items = sortByName(normalizeItems(dataset));
const filters = buildFilterOptions(items);
const updated = datasetUpdatedLabel(dataset);
const needsVerification = countNeedsVerification(items);

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const databaseId = `tool-db-${title.toLowerCase().replace(/[^a-z0-9]+/g, '-')}`;
---

<BaseLayout
  title={`${title} | DivGaming Astro Staging`}
  description={description}
  canonical={canonical}
  noindex={true}
>
  <section class="shell tools-hero">
    <div class="tools-hero__content">
      <p class="eyebrow">{eyebrow}</p>
      <h1>{title}</h1>
      <p class="lead">{description}</p>
      <div class="tools-hero__actions">
        <a class="button" href={`${base}/division-2/tools/`}>All tools</a>
        <a class="button button--ghost" href={`${base}/division-2/`}>Division 2 hub</a>
      </div>
    </div>

    <aside class="tools-hero__panel card">
      <p class="eyebrow">Dataset</p>
      <h2>{items.length}</h2>
      <p>records loaded from the Astro data layer.</p>
      {updated && <p class="tools-hero__updated">Updated: {updated}</p>}
      {needsVerification > 0 && (
        <p class="tools-hero__updated">{needsVerification} records marked for verification.</p>
      )}
    </aside>
  </section>

  {featuredItems.length > 0 && (
    <section class="shell section">
      <p class="eyebrow">Featured references</p>
      <div class="grid featured-grid">
        {featuredItems.slice(0, 3).map((item) => (
          <ToolItemCard item={item} compact={true} />
        ))}
      </div>
    </section>
  )}

  <section class="shell section" id={databaseId} data-tool-database>
    <div class="section-heading">
      <div>
        <p class="eyebrow">Reference database</p>
        <h2><span data-result-count>{items.length}</span> entries</h2>
      </div>
      <p>
        Search and filter this database instantly. This is still staging, but it
        now behaves like an actual DivGaming tool.
      </p>
    </div>

    <div class="tool-controls card">
      <label class="tool-search">
        <span>Search this database</span>
        <input
          type="search"
          placeholder="Search names, talents, slots, sources..."
          data-tool-search
        />
      </label>

      {filters.length > 0 && (
        <div class="tool-filters" aria-label="Database filters">
          <button type="button" class="active" data-tool-filter="all">All</button>
          {filters.map((filter) => (
            <button type="button" data-tool-filter={filter.value}>{filter.label}</button>
          ))}
        </div>
      )}

      <button type="button" class="tool-reset" data-tool-reset>Reset filters</button>
    </div>

    {items.length > 0 ? (
      <>
        <div class="grid tool-grid" data-tool-grid>
          {items.map((item) => (
            <ToolItemCard item={item} />
          ))}
        </div>

        <div class="card empty-state" data-empty-state hidden>
          <p class="eyebrow">No results</p>
          <h2>No matching entries found.</h2>
          <p>Try a broader term or reset the filter chips.</p>
        </div>
      </>
    ) : (
      <div class="card empty-state">
        <h2>{emptyMessage}</h2>
      </div>
    )}
  </section>

  <script>
    function initToolDatabase(database) {
      const searchInput = database.querySelector('[data-tool-search]');
      const cards = [...database.querySelectorAll('[data-tool-card]')];
      const filterButtons = [...database.querySelectorAll('[data-tool-filter]')];
      const count = database.querySelector('[data-result-count]');
      const reset = database.querySelector('[data-tool-reset]');
      const emptyState = database.querySelector('[data-empty-state]');
      let activeFilter = 'all';

      function applyFilters() {
        const query = (searchInput?.value || '').trim().toLowerCase();
        let visible = 0;

        for (const card of cards) {
          const search = card.dataset.search || '';
          const filters = (card.dataset.filters || '').split(' ');
          const matchesSearch = !query || search.includes(query);
          const matchesFilter = activeFilter === 'all' || filters.includes(activeFilter);
          const shouldShow = matchesSearch && matchesFilter;

          card.hidden = !shouldShow;
          if (shouldShow) visible += 1;
        }

        if (count) count.textContent = String(visible);
        if (emptyState) emptyState.hidden = visible !== 0;
      }

      searchInput?.addEventListener('input', applyFilters);

      for (const button of filterButtons) {
        button.addEventListener('click', () => {
          activeFilter = button.dataset.toolFilter || 'all';

          for (const item of filterButtons) {
            item.classList.toggle('active', item === button);
          }

          applyFilters();
        });
      }

      reset?.addEventListener('click', () => {
        if (searchInput) searchInput.value = '';
        activeFilter = 'all';

        for (const button of filterButtons) {
          button.classList.toggle('active', button.dataset.toolFilter === 'all');
        }

        applyFilters();
      });

      applyFilters();
    }

    for (const database of document.querySelectorAll('[data-tool-database]')) {
      initToolDatabase(database);
    }
  </script>

  <style>
    .tools-hero {
      display: grid;
      grid-template-columns: minmax(0, 1.35fr) minmax(260px, 0.65fr);
      gap: 20px;
      padding-top: 40px;
      align-items: stretch;
    }

    .tools-hero__content {
      border: 1px solid rgba(255, 107, 0, 0.16);
      border-radius: 28px;
      padding: clamp(24px, 5vw, 54px);
      background:
        radial-gradient(circle at top left, rgba(255, 107, 0, 0.24), transparent 42%),
        linear-gradient(140deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.025));
      box-shadow: var(--dg-shadow);
    }

    .tools-hero h1 {
      margin: 0;
      font-size: clamp(2.45rem, 7vw, 5.4rem);
      line-height: 0.92;
      letter-spacing: -0.065em;
      text-transform: uppercase;
    }

    .tools-hero__actions {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      margin-top: 24px;
    }

    .tools-hero__panel {
      padding: 22px;
    }

    .tools-hero__panel h2 {
      margin: 0;
      color: var(--dg-orange);
      font-size: clamp(3rem, 9vw, 6rem);
      line-height: 0.9;
      letter-spacing: -0.065em;
    }

    .tools-hero__panel p {
      color: var(--dg-muted);
    }

    .tools-hero__updated {
      border-top: 1px solid rgba(255, 255, 255, 0.08);
      padding-top: 12px;
      font-size: 0.88rem;
    }

    .featured-grid {
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    }

    .section-heading {
      display: flex;
      justify-content: space-between;
      gap: 20px;
      align-items: end;
      margin-bottom: 20px;
    }

    .section-heading h2 {
      margin: 0;
      font-size: clamp(1.9rem, 4vw, 3.2rem);
      letter-spacing: -0.045em;
    }

    .section-heading > p {
      max-width: 560px;
      margin: 0;
      color: var(--dg-muted);
    }

    .tool-controls {
      display: grid;
      gap: 16px;
      margin-bottom: 20px;
      padding: 18px;
    }

    .tool-search {
      display: grid;
      gap: 8px;
    }

    .tool-search span {
      color: var(--dg-muted);
      font-size: 0.8rem;
      font-weight: 950;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    .tool-search input {
      width: 100%;
      border: 1px solid rgba(255, 107, 0, 0.28);
      border-radius: 16px;
      padding: 14px 15px;
      color: var(--dg-text);
      background: rgba(0, 0, 0, 0.28);
      font: inherit;
      outline: none;
    }

    .tool-search input:focus {
      border-color: var(--dg-orange);
      box-shadow: 0 0 0 3px rgba(255, 107, 0, 0.12);
    }

    .tool-filters {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .tool-filters button,
    .tool-reset {
      border: 1px solid rgba(255, 107, 0, 0.24);
      border-radius: 999px;
      padding: 8px 11px;
      color: var(--dg-muted);
      background: rgba(255, 255, 255, 0.045);
      font: inherit;
      font-size: 0.84rem;
      font-weight: 900;
      cursor: pointer;
    }

    .tool-filters button:hover,
    .tool-filters button.active,
    .tool-reset:hover {
      color: #160d05;
      background: var(--dg-orange);
      border-color: var(--dg-orange);
    }

    .tool-reset {
      justify-self: start;
    }

    .tool-grid {
      grid-template-columns: repeat(auto-fill, minmax(315px, 1fr));
      align-items: stretch;
    }

    .empty-state {
      padding: 22px;
    }

    @media (max-width: 900px) {
      .tools-hero,
      .section-heading {
        display: grid;
        grid-template-columns: 1fr;
      }

      .tools-hero {
        padding-top: 24px;
      }

      .section-heading {
        align-items: start;
      }
    }
  </style>
</BaseLayout>
