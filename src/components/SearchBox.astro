---
import Icon from './Icon.astro';
export interface Props { id: string; compact?: boolean; }
const { id, compact = false } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const items = [
  ['Division 2 Hub', 'Hub', '/division-2/', 'home sections main'],
  ['Gear Tools', 'Tools', '/division-2/tools/', 'gear tools database items talents'],
  ['Exotic Source Tracker', 'Tools', '/division-2/tools/exotic-source-tracker/', 'exotics source tracker'],
  ['Named Items Database', 'Tools', '/division-2/tools/named-items-database/', 'named items perfect talents'],
  ['Brand Set Database', 'Tools', '/division-2/tools/brand-set-database/', 'brand sets high end'],
  ['Gearset Matrix', 'Tools', '/division-2/tools/gearset-matrix/', 'gearsets green sets'],
  ['Gear Talents', 'Tools', '/division-2/tools/gear-talents/', 'gear talents chest backpack'],
  ['Weapon Talents', 'Tools', '/division-2/tools/weapon-talents/', 'weapon talents'],
  ['Build Library', 'Builds', '/division-2/builds/', 'builds videos loadouts'],
  ['Striker Builds', 'Builds', '/division-2/builds/striker/', 'striker builds'],
  ['PvE Builds', 'Builds', '/division-2/builds/pve/', 'pve raids countdown incursion'],
  ['Solo Builds', 'Builds', '/division-2/builds/solo/', 'solo builds'],
  ['PvP Builds', 'Builds', '/division-2/builds/pvp/', 'pvp dark zone conflict'],
  ['Video Library', 'Videos', '/division-2/videos/', 'creator videos youtube'],
  ['Saved Builds', 'Builds', '/division-2/saved/', 'saved builds bookmarks later'],
  ['Creators', 'Creators', '/division-2/creators/', 'creators channels'],
  ['Guides', 'Guides', '/division-2/guides/', 'guides help farming returning']
].map(([title, type, href, keywords]) => ({ title, type, href: `${base}${href}`, keywords }));
---

<div class:list={['searchbox', compact && 'searchbox-compact']} data-search-root>
  <Icon name="search" />
  <input id={id} type="search" placeholder="Search builds, tools, guides..." data-search-input autocomplete="off" />
  <div class="search-results" data-search-results></div>
  <script type="application/json" data-search-data>{JSON.stringify(items)}</script>
</div>

<script>
  for (const root of document.querySelectorAll('[data-search-root]')) {
    const input = root.querySelector('[data-search-input]');
    const results = root.querySelector('[data-search-results]');
    const data = JSON.parse(root.querySelector('[data-search-data]')?.textContent || '[]');

    function render() {
      const q = (input?.value || '').toLowerCase().trim();
      if (!q) {
        root.classList.remove('is-open');
        results.innerHTML = '';
        return;
      }

      const matches = data.filter((item) => `${item.title} ${item.type} ${item.keywords}`.toLowerCase().includes(q)).slice(0, 7);
      results.innerHTML = matches.length
        ? matches.map((item) => `<a href="${item.href}"><span>${item.type}</span><strong>${item.title}</strong></a>`).join('')
        : '<p>No matching section found.</p>';
      root.classList.add('is-open');
    }

    input?.addEventListener('input', render);
    input?.addEventListener('focus', render);
    input?.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') root.classList.remove('is-open');
      if (event.key === 'Enter') {
        const first = results.querySelector('a');
        if (first) window.location.href = first.href;
      }
    });

    document.addEventListener('click', (event) => {
      if (!root.contains(event.target)) root.classList.remove('is-open');
    });
  }
</script>
