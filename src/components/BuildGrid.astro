---
import DiscoveryControls from './DiscoveryControls.astro';
import VideoCard from './VideoCard.astro';
import { buildDiscoveryFilters, type BuildVideo } from '../utils/builds';

export interface Props {
  videos: BuildVideo[];
  enableControls?: boolean;
}

const { videos, enableControls = true } = Astro.props;
const filters = buildDiscoveryFilters(videos);
---

{enableControls && (
  <DiscoveryControls count={videos.length} filters={filters} />
)}

{videos.length > 0 ? (
  <>
    <div class="grid video-grid">
      {videos.map((video) => (
        <VideoCard video={video} />
      ))}
    </div>

    <div class="card empty-state" data-discovery-empty hidden>
      <p class="eyebrow">No results</p>
      <h2>No matching videos found.</h2>
      <p>Try another creator, tag, build type, or reset the filters.</p>
    </div>
  </>
) : (
  <div class="card empty-state">
    <p class="eyebrow">No videos</p>
    <h2>No videos found for this route yet.</h2>
  </div>
)}

<style>
  .video-grid {
    grid-template-columns: repeat(auto-fill, minmax(310px, 1fr));
    align-items: stretch;
  }

  .empty-state {
    padding: 24px;
  }

  .empty-state h2 {
    margin: 0;
    font-size: clamp(1.7rem, 4vw, 2.8rem);
    letter-spacing: -0.045em;
  }

  .empty-state p:not(.eyebrow) {
    color: var(--dg-muted);
  }
</style>
