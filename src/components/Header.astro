---
import Icon from './Icon.astro';
import SearchBox from './SearchBox.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const withBase = (href: string) => href.startsWith('http') ? href : `${base}${href}`;

const nav = [
  ['Tools', '/division-2/tools/'],
  ['Builds', '/division-2/builds/'],
  ['Videos', '/division-2/videos/'],
  ['Creators', '/division-2/creators/'],
  ['Guides', '/division-2/guides/']
];
---

<header class="site-header">
  <nav class="site-nav shell">
    <a class="brand" href={withBase('/')}>
      <img src={withBase('/assets/img/dg-logo-128.webp')} alt="DivGaming logo" />
      <strong>DivGaming.com</strong>
    </a>

    <div class="desktop-search">
      <SearchBox id="desktop-search" />
    </div>

    <button class="menu-button" type="button" data-menu-toggle aria-expanded="false">
      <Icon name="menu" />
      Menu
    </button>

    <div class="nav-links" data-menu-panel>
      {nav.map(([label, href]) => <a href={withBase(href)}>{label}</a>)}
    </div>
  </nav>

  <div class="mobile-search shell">
    <SearchBox id="mobile-search" compact={true} />
  </div>

  <script>
    const button = document.querySelector('[data-menu-toggle]');
    const panel = document.querySelector('[data-menu-panel]');
    button?.addEventListener('click', () => {
      const open = button.getAttribute('aria-expanded') === 'true';
      button.setAttribute('aria-expanded', String(!open));
      panel?.classList.toggle('is-open', !open);
    });
  </script>
</header>
