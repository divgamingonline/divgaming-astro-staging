---
import VideoCard from './VideoCard.astro';
import { getCategoryVideos, type BuildVideo } from '../utils/videos';

export interface Props {
  data: any;
  category?: string;
}

const { data, category = 'all' } = Astro.props;
const videos = getCategoryVideos(data, category);
---

<section class="shell section" data-video-library>
  <div class="section-head">
    <p class="eyebrow">Video Library</p>
    <h2><span data-video-count>{videos.length}</span> videos</h2>
    <p>Search by creator, title, build type, activity, or tag. Videos open directly on YouTube.</p>
  </div>

  <div class="filter-panel">
    <input type="search" placeholder="Search videos and builds..." data-video-search />
    <button type="button" data-video-filter-toggle>Filters</button>
    <button type="button" data-video-reset>Reset</button>
    <div class="filter-buttons" data-video-filters>
      {['all', 'striker', 'pve', 'solo', 'pvp', 'farming', 'damage', 'armor', 'skill'].map((filter) => (
        <button type="button" class={filter === 'all' ? 'active' : ''} data-filter={filter}>{filter}</button>
      ))}
    </div>
  </div>

  <div class="video-grid">
    {videos.map((video: BuildVideo) => <VideoCard video={video} />)}
  </div>

  <div class="empty-state" data-video-empty hidden>
    <h2>No matching videos found.</h2>
    <p>Try a broader search term or reset the filters.</p>
  </div>
</section>

<script>
  function savedBuilds() {
    try { return JSON.parse(localStorage.getItem('divgamingSavedBuilds') || '[]'); }
    catch { return []; }
  }

  function setSavedBuilds(items) {
    localStorage.setItem('divgamingSavedBuilds', JSON.stringify(items));
  }

  function updateSaveButtons() {
    const saved = savedBuilds();
    const urls = new Set(saved.map((item) => item.url));
    for (const button of document.querySelectorAll('[data-save-build]')) {
      const isSaved = urls.has(button.dataset.saveUrl);
      button.classList.toggle('is-saved', isSaved);
      button.innerHTML = isSaved ? 'Saved' : 'Save';
    }
  }

  for (const button of document.querySelectorAll('[data-save-build]')) {
    button.addEventListener('click', () => {
      const item = {
        title: button.dataset.saveTitle,
        creator: button.dataset.saveCreator,
        url: button.dataset.saveUrl,
        savedAt: new Date().toISOString()
      };

      const saved = savedBuilds();
      const exists = saved.some((entry) => entry.url === item.url);
      const next = exists ? saved.filter((entry) => entry.url !== item.url) : [item, ...saved].slice(0, 100);
      setSavedBuilds(next);
      updateSaveButtons();
    });
  }

  updateSaveButtons();

  for (const root of document.querySelectorAll('[data-video-library]')) {
    const input = root.querySelector('[data-video-search]');
    const cards = [...root.querySelectorAll('[data-video-card]')];
    const buttons = [...root.querySelectorAll('[data-filter]')];
    const count = root.querySelector('[data-video-count]');
    const empty = root.querySelector('[data-video-empty]');
    const reset = root.querySelector('[data-video-reset]');
    const filterPanel = root.querySelector('[data-video-filters]');
    const filterToggle = root.querySelector('[data-video-filter-toggle]');
    let active = 'all';

    function closeMobileFilters() {
      if (window.matchMedia('(max-width: 780px)').matches) {
        filterPanel?.classList.remove('is-open');
      }
    }

    function apply() {
      const q = (input?.value || '').toLowerCase().trim();
      let visible = 0;

      for (const card of cards) {
        const search = card.dataset.search || '';
        const filters = card.dataset.filters || '';
        const okSearch = !q || search.includes(q);
        const okFilter = active === 'all' || filters.includes(active);
        const show = okSearch && okFilter;
        card.hidden = !show;
        if (show) visible++;
      }

      count.textContent = String(visible);
      empty.hidden = visible !== 0;
    }

    input?.addEventListener('input', apply);
    filterToggle?.addEventListener('click', () => filterPanel?.classList.toggle('is-open'));

    for (const button of buttons) {
      button.addEventListener('click', () => {
        active = button.dataset.filter || 'all';
        buttons.forEach((item) => item.classList.toggle('active', item === button));
        apply();
        closeMobileFilters();
      });
    }

    reset?.addEventListener('click', () => {
      input.value = '';
      active = 'all';
      buttons.forEach((item) => item.classList.toggle('active', item.dataset.filter === 'all'));
      apply();
      closeMobileFilters();
    });
  }
</script>
