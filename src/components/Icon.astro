};

const paths = icons[name] || icons.arrow;
---

<svg class:list={['icon', className]} width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
  {paths.map((path) => <Fragment set:html={`<${path}/>`} />)}
</svg>
