---
export interface Props {
  name: string;
  size?: number;
  strokeWidth?: number;
  class?: string;
  ariaLabel?: string;
}

const {
  name,
  size = 20,
  strokeWidth = 2,
  class: className = '',
  ariaLabel
} = Astro.props;

const icons: Record<string, string[]> = {
  search: ['circle cx="11" cy="11" r="8"', 'path d="m21 21-4.3-4.3"'],
  'arrow-right': ['path d="M5 12h14"', 'path d="m12 5 7 7-7 7"'],
  backpack: ['path d="M4 10a8 8 0 0 1 16 0v8a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2z"', 'path d="M8 10V8a4 4 0 0 1 8 0v2"', 'path d="M8 14h8"', 'path d="M8 18v-2"', 'path d="M16 18v-2"'],
  database: ['ellipse cx="12" cy="5" rx="9" ry="3"', 'path d="M3 5v14c0 1.7 4 3 9 3s9-1.3 9-3V5"', 'path d="M3 12c0 1.7 4 3 9 3s9-1.3 9-3"'],
  'check-circle': ['path d="M22 11.1V12a10 10 0 1 1-5.9-9.1"', 'path d="m9 11 3 3L22 4"'],
  video: ['path d="m22 8-6 4 6 4V8Z"', 'rect x="2" y="6" width="14" height="12" rx="2"'],
  'book-open': ['path d="M12 7v14"', 'path d="M3 18a1 1 0 0 1-1-1V5a2 2 0 0 1 2-2h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3Z"', 'path d="M21 18a1 1 0 0 0 1-1V5a2 2 0 0 0-2-2h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3Z"'],
  coffee: ['path d="M10 2v2"', 'path d="M14 2v2"', 'path d="M16 8h1a4 4 0 0 1 0 8h-1"', 'path d="M4 8h12v6a4 4 0 0 1-4 4H8a4 4 0 0 1-4-4Z"', 'path d="M6 22h12"'],
  home: ['path d="m3 11 9-8 9 8"', 'path d="M5 10v10a1 1 0 0 0 1 1h4v-6h4v6h4a1 1 0 0 0 1-1V10"'],
  users: ['path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"', 'circle cx="9" cy="7" r="4"', 'path d="M22 21v-2a4 4 0 0 0-3-3.87"', 'path d="M16 3.13a4 4 0 0 1 0 7.75"'],
  route: ['circle cx="6" cy="19" r="3"', 'circle cx="18" cy="5" r="3"', 'path d="M12 19h3.5a3.5 3.5 0 0 0 0-7H8.5a3.5 3.5 0 0 1 0-7H12"'],
  menu: ['path d="M4 6h16"', 'path d="M4 12h16"', 'path d="M4 18h16"'],
  download: ['path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"', 'path d="M7 10l5 5 5-5"', 'path d="M12 15V3"'],
  shield: ['path d="M20 13c0 5-3.5 7.5-8 9-4.5-1.5-8-4-8-9V5l8-3 8 3Z"'],
  crosshair: ['circle cx="12" cy="12" r="10"', 'path d="M22 12h-4"', 'path d="M6 12H2"', 'path d="M12 6V2"', 'path d="M12 22v-4"', 'circle cx="12" cy="12" r="2"'],
  'list-filter': ['path d="M3 6h18"', 'path d="M7 12h10"', 'path d="M10 18h4"'],
  'external-link': ['path d="M15 3h6v6"', 'path d="M10 14 21 3"', 'path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"']
};

const paths = icons[name] || icons['check-circle'];
const ariaAttrs = ariaLabel
  ? { role: 'img', 'aria-label': ariaLabel }
  : { 'aria-hidden': 'true' };
---

<svg
  class:list={['lucide-icon', className]}
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width={strokeWidth}
  stroke-linecap="round"
  stroke-linejoin="round"
  {...ariaAttrs}
>
  {paths.map((path) => <Fragment set:html={`<${path}/>`} />)}
</svg>
