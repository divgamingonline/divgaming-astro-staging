---
import {
  discoveryFilterTokens,
  discoverySearchText,
  formatDate,
  formatNumber,
  youtubeThumbnail,
  youtubeThumbnailFallback,
  youtubeThumbnailFinalFallback,
  youtubeWatchUrl,
  videoCategory,
  videoPath,
  videoTags,
  type BuildVideo
} from '../utils/builds';

export interface Props {
  video: BuildVideo;
}

const { video } = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

function withBase(href: string) {
  if (href.startsWith('http')) return href;
  return `${base}${href}`;
}

const thumbnail = youtubeThumbnail(video);
const fallback = youtubeThumbnailFallback(video);
const finalFallback = youtubeThumbnailFinalFallback(video);
const tags = videoTags(video);
const category = videoCategory(video);
const watchUrl = youtubeWatchUrl(video);
const detailHref = withBase(videoPath(video));
const dateLabel = formatDate(video.date);
const viewsLabel = formatNumber(video.views);
const searchText = discoverySearchText(video);
const filters = discoveryFilterTokens(video).join(' ');
---

<article class="video-card card" data-discovery-card data-search={searchText} data-filters={filters}>
  <a class="video-card__media" href={detailHref} aria-label={`Open ${video.title}`}>
    {thumbnail ? (
      <img
        src={thumbnail}
        alt=""
        loading="lazy"
        data-fallback={fallback}
        data-final-fallback={finalFallback}
        onerror="if (this.dataset.fallback && this.src !== this.dataset.fallback) { this.src = this.dataset.fallback; this.dataset.fallback = ''; } else if (this.dataset.finalFallback && this.src !== this.dataset.finalFallback) { this.src = this.dataset.finalFallback; this.dataset.finalFallback = ''; }"
      />
    ) : (
      <div class="video-card__placeholder">VIDEO</div>
    )}
    <span class="video-card__badge">{category}</span>
  </a>

  <div class="video-card__body">
    <p class="mission-kicker">{video.creator}</p>
    <h3><a href={detailHref}>{video.title}</a></h3>

    <div class="video-card__meta">
      {dateLabel && <span>{dateLabel}</span>}
      {viewsLabel && <span>{viewsLabel} views</span>}
    </div>

    {video.description && <p>{video.description}</p>}

    {tags.length > 0 && (
      <div class="badge-row video-card__tags">
        {tags.slice(0, 5).map((tag) => (
          <span>{tag}</span>
        ))}
      </div>
    )}

    <div class="video-card__actions">
      <a class="btn primary" href={watchUrl} target="_blank" rel="noopener noreferrer">Watch on YouTube</a>
      <a class="btn ghost" href={detailHref}>Video Details</a>
    </div>
  </div>
</article>
