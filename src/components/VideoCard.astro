---
import Icon from './Icon.astro';
import {
  videoCreator,
  videoDescription,
  videoFilterTokens,
  videoMeta,
  videoSearch,
  videoTags,
  videoThumb,
  videoTitle,
  videoUrl,
  type BuildVideo
} from '../utils/videos';

export interface Props { video: BuildVideo; }
const { video } = Astro.props;
const url = videoUrl(video);
const thumb = videoThumb(video);
const title = videoTitle(video);
const creator = videoCreator(video);
const tags = videoTags(video);
const key = String(video.id || video.videoId || url);
---

<article class="video-card" data-video-card data-video-key={key} data-search={videoSearch(video)} data-filters={videoFilterTokens(video).join(' ')}>
  <a class="video-thumb" href={url} target="_blank" rel="noopener">
    {thumb ? <img src={thumb} alt="" loading="lazy" /> : <span>VIDEO</span>}
  </a>
  <div class="video-body">
    <p class="eyebrow">{creator}</p>
    <h3>{title}</h3>
    {videoMeta(video) && <p class="video-meta">{videoMeta(video)}</p>}
    <p>{videoDescription(video)}</p>
    {tags.length > 0 && (
      <div class="chip-row">
        {tags.slice(0, 5).map((tag) => <span>{tag}</span>)}
      </div>
    )}
    <div class="video-actions">
      <a class="button primary" href={url} target="_blank" rel="noopener">Watch on YouTube</a>
      <button class="button ghost save-build" type="button" data-save-build data-save-title={title} data-save-creator={creator} data-save-url={url}>
        <Icon name="save" />
        Save
      </button>
    </div>
  </div>
</article>
