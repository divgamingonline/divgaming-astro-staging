---
import Icon from './Icon.astro';

export interface Props {
  videosIndexed?: number;
  creatorsIndexed?: number;
  toolRecords?: number;
}

const { videosIndexed = 0, creatorsIndexed = 0, toolRecords = 0 } = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const coffeeUrl = 'https://buymeacoffee.com/divgamingoy';

function withBase(href: string) {
  if (href.startsWith('http')) return href;
  return `${base}${href}`;
}

const socialLinks = [
  { label: 'Discord', href: '#', icon: '/assets/img/socials/discord.png' },
  { label: 'YouTube', href: '#', icon: '/assets/img/socials/youtube.png' },
  { label: 'Twitch', href: '#', icon: '/assets/img/socials/twitch.png' },
  { label: 'TikTok', href: '#', icon: '/assets/img/socials/tiktok.png' },
  { label: 'Instagram', href: '#', icon: '/assets/img/socials/instagram.png' },
  { label: 'X', href: '#', icon: '/assets/img/socials/x.png' }
];

const dispatchItems = [
  {
    icon: 'check-circle',
    label: 'Current Focus',
    value: 'Staging Review'
  },
  {
    icon: 'video',
    label: 'Creator Traffic',
    value: 'YouTube Direct'
  },
  {
    icon: 'database',
    label: 'Data Layer',
    value: 'JSON Driven'
  },
  {
    icon: 'shield',
    label: 'Cutover Status',
    value: 'Not Yet'
  }
];
---

<footer class="site-footer">
  <div class="shell footer-grid">
    <div class="footer-info">
      <div class="footer-brand-row">
        <img class="footer-logo" src={withBase('/assets/img/dg-logo.png')} alt="DivGaming logo" loading="lazy" />
        <strong>DivGaming.com</strong>
      </div>

      <p class="footer-tagline">
        Community-built Division 2 network hub for tools, creator content,
        guides, maps, vendor resources, and active agents.
      </p>

      <div class="footer-network-stats" aria-label="DivGaming network stats">
        <div>
          <strong>{videosIndexed}</strong>
          <span>Videos Indexed</span>
        </div>
        <div>
          <strong>{creatorsIndexed}</strong>
          <span>Active SHD Agents</span>
        </div>
        <div>
          <strong>{toolRecords}</strong>
          <span>Tool Records</span>
        </div>
        <div>
          <strong class="status-active">Active</strong>
          <span>ISAC Network</span>
        </div>
      </div>

      <div class="footer-socials" aria-label="DivGaming social links">
        {socialLinks.map((item) => (
          <a href={item.href} aria-label={item.label}>
            <img src={withBase(item.icon)} alt="" loading="lazy" />
          </a>
        ))}
      </div>

      <p class="footer-disclaimer">
        DivGaming.com is an independent community project and is not affiliated
        with Ubisoft, Massive Entertainment, or The Division franchise.
      </p>
      <p class="footer-copy">
        © 2026 DivGaming.com. All original site design, DivGaming branding,
        layout, and written content are reserved by DivGaming.com.
      </p>
      <p class="footer-credit">
        Built for the Division Community by <strong>ItsSandman</strong>
        <span class="credit-divider">//</span>
        The SHD Network survives because agents keep it alive.
      </p>
    </div>

    <div class="footer-actions">
      <div class="support-card">
        <span>Support the project</span>
        <div class="support-project">
          <div class="support-project-head">
            <strong>Weekly Project</strong>
            <small>Mission Impact</small>
          </div>
          <p>Help keep the SHD Network operational for Division agents worldwide.</p>
          <div class="support-impact-grid">
            <span>Network maintenance</span>
            <span>Resource updates</span>
            <span>Creator tracking</span>
            <span>Future development</span>
          </div>
        </div>
        <a href={coffeeUrl} target="_blank" rel="noopener">
          <Icon name="coffee" />
          Contribute Resources
        </a>
      </div>

      <div class="footer-bottom-row">
        <button id="install-btn" class="btn ghost install-btn" style="display:none">
          <Icon name="download" />
          <span>Add DivGaming to my device</span>
        </button>
        <a class="back-top" href="#top">Back to top ↑</a>
      </div>
    </div>
  </div>

  <div class="shell footer-dispatch-band" aria-label="SHD Dispatch">
    <div class="footer-dispatch-band__intro">
      <p class="eyebrow">SHD Dispatch</p>
      <strong>Launch candidate status</strong>
      <span>Astro staging is being tightened for function, stability, production parity, and clean cutover readiness.</span>
    </div>

    <div class="footer-dispatch-band__items">
      {dispatchItems.map((item) => (
        <div class="footer-dispatch-band__item">
          <Icon name={item.icon} />
          <span>{item.label}</span>
          <strong>{item.value}</strong>
        </div>
      ))}
    </div>

    <div class="footer-dispatch-band__actions">
      <a href={withBase('/division-2/')}>Review Hub</a>
      <a href={withBase('/division-2/tools/')}>Check Tools</a>
    </div>
  </div>

  <style>
    .footer-dispatch-band {
      position: relative;
      z-index: 1;
      display: grid;
      grid-template-columns: minmax(260px, 1fr) minmax(420px, 1.35fr) auto;
      gap: 20px;
      align-items: center;
      margin-top: 28px;
      border-top: 1px solid rgba(255, 107, 0, 0.18);
      border-bottom: 1px solid rgba(255, 107, 0, 0.18);
      padding: 18px 0;
    }

    .footer-dispatch-band__intro {
      min-width: 0;
    }

    .footer-dispatch-band__intro .eyebrow {
      margin-bottom: 4px;
    }

    .footer-dispatch-band__intro strong {
      display: block;
      color: #fff;
      font-family: 'Chakra Petch', sans-serif;
      font-size: 1.05rem;
      line-height: 1.15;
    }

    .footer-dispatch-band__intro span {
      display: block;
      margin-top: 6px;
      color: var(--muted);
      font-size: 0.88rem;
      line-height: 1.45;
    }

    .footer-dispatch-band__items {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 8px;
      min-width: 0;
    }

    .footer-dispatch-band__item {
      display: grid;
      grid-template-columns: auto minmax(0, 1fr);
      grid-template-areas:
        "icon label"
        "icon value";
      column-gap: 8px;
      align-items: center;
      min-height: 58px;
      border-left: 1px solid rgba(255, 107, 0, 0.22);
      padding: 8px 10px;
      background: linear-gradient(90deg, rgba(255, 107, 0, 0.055), transparent);
    }

    .footer-dispatch-band__item .lucide-icon {
      grid-area: icon;
      color: var(--orange-2);
      width: 18px;
      height: 18px;
    }

    .footer-dispatch-band__item span {
      grid-area: label;
      color: var(--muted);
      font-family: 'Chakra Petch', sans-serif;
      font-size: 0.62rem;
      font-weight: 900;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .footer-dispatch-band__item strong {
      grid-area: value;
      color: var(--green);
      font-family: 'Chakra Petch', sans-serif;
      font-size: 0.86rem;
      line-height: 1.1;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .footer-dispatch-band__actions {
      display: flex;
      flex-wrap: wrap;
      justify-content: flex-end;
      gap: 8px;
    }

    .footer-dispatch-band__actions a {
      display: inline-flex;
      justify-content: center;
      align-items: center;
      min-height: 36px;
      border: 1px solid rgba(255, 107, 0, 0.28);
      border-radius: 999px;
      padding: 0 12px;
      color: rgba(217, 242, 238, 0.9);
      background: rgba(255, 107, 0, 0.055);
      font-family: 'Chakra Petch', sans-serif;
      font-size: 0.7rem;
      font-weight: 900;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      white-space: nowrap;
    }

    .footer-dispatch-band__actions a:hover {
      color: #160d05;
      background: var(--orange);
      border-color: var(--orange);
    }

    @media (max-width: 1120px) {
      .footer-dispatch-band {
        grid-template-columns: 1fr;
        align-items: start;
      }

      .footer-dispatch-band__actions {
        justify-content: flex-start;
      }
    }

    @media (max-width: 780px) {
      .footer-dispatch-band {
        gap: 14px;
        margin-top: 22px;
        padding: 16px 0;
      }

      .footer-dispatch-band__items {
        display: flex;
        overflow-x: auto;
        gap: 8px;
        padding-bottom: 2px;
        scrollbar-width: none;
      }

      .footer-dispatch-band__items::-webkit-scrollbar {
        display: none;
      }

      .footer-dispatch-band__item {
        flex: 0 0 185px;
      }

      .footer-dispatch-band__actions {
        display: grid;
        grid-template-columns: 1fr 1fr;
      }

      .footer-dispatch-band__actions a {
        width: 100%;
      }
    }
  </style>
</footer>
