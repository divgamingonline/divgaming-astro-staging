---
import Icon from './Icon.astro';

export interface Props {
  videosIndexed?: number;
  creatorsIndexed?: number;
  toolRecords?: number;
}

const { videosIndexed = 0, creatorsIndexed = 0, toolRecords = 0 } = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const coffeeUrl = 'https://buymeacoffee.com/divgamingoy';

function withBase(href: string) {
  if (href.startsWith('http')) return href;
  return `${base}${href}`;
}

const socialLinks = [
  { label: 'Discord', href: '#', icon: '/assets/img/socials/discord.png' },
  { label: 'YouTube', href: '#', icon: '/assets/img/socials/youtube.png' },
  { label: 'Twitch', href: '#', icon: '/assets/img/socials/twitch.png' },
  { label: 'TikTok', href: '#', icon: '/assets/img/socials/tiktok.png' },
  { label: 'Instagram', href: '#', icon: '/assets/img/socials/instagram.png' },
  { label: 'X', href: '#', icon: '/assets/img/socials/x.png' }
];

const dispatchItems = [
  {
    icon: 'check-circle',
    label: 'Current Focus',
    value: 'Staging Review',
    text: 'The Astro version is being reviewed for function, stability, and content clarity before launch.'
  },
  {
    icon: 'video',
    label: 'Creator Traffic',
    value: 'YouTube Direct',
    text: 'Creator videos are indexed for discovery, but playback stays on the original YouTube channel.'
  },
  {
    icon: 'database',
    label: 'Data Layer',
    value: 'JSON Driven',
    text: 'Builds, tools, gear, talents, and video entries are powered by maintainable data files.'
  },
  {
    icon: 'shield',
    label: 'Cutover Status',
    value: 'Not Yet',
    text: 'The live DivGaming.com site stays untouched until staging passes the full review.'
  }
];
---

<footer class="site-footer">
  <div class="shell footer-grid">
    <div class="footer-info">
      <div class="footer-brand-row">
        <img class="footer-logo" src={withBase('/assets/img/dg-logo.png')} alt="DivGaming logo" loading="lazy" />
        <strong>DivGaming.com</strong>
      </div>

      <p class="footer-tagline">
        A Division 2 community hub for builds, gear tools, creator videos,
        guides, maps, vendor resources, and player-friendly reference material.
      </p>

      <div class="footer-network-stats" aria-label="DivGaming network stats">
        <div>
          <strong>{videosIndexed}</strong>
          <span>Videos Indexed</span>
        </div>
        <div>
          <strong>{creatorsIndexed}</strong>
          <span>Creators Listed</span>
        </div>
        <div>
          <strong>{toolRecords}</strong>
          <span>Tool Records</span>
        </div>
        <div>
          <strong class="status-active">Active</strong>
          <span>Staging Review</span>
        </div>
      </div>

      <p class="footer-disclaimer">
        DivGaming.com is an independent community project and is not affiliated
        with Ubisoft, Massive Entertainment, or The Division franchise.
      </p>
      <p class="footer-copy">
        © 2026 DivGaming.com. All original site design, DivGaming branding,
        layout, and written content are reserved by DivGaming.com.
      </p>
      <p class="footer-credit">
        Built for the Division community by <strong>ItsSandman</strong>
        <span class="credit-divider">//</span>
        Built to help players find useful information faster.
      </p>
    </div>

    <div class="footer-actions">
      <div class="footer-social-card">
        <div>
          <p class="eyebrow">Connect</p>
          <strong>Follow DivGaming</strong>
        </div>

        <div class="footer-socials" aria-label="DivGaming social links">
          {socialLinks.map((item) => (
            <a href={item.href} aria-label={item.label}>
              <img src={withBase(item.icon)} alt="" loading="lazy" />
            </a>
          ))}
        </div>
      </div>

      <div class="support-card">
        <span>Support the project</span>
        <div class="support-project">
          <div class="support-project-head">
            <strong>Weekly Project</strong>
            <small>Community Support</small>
          </div>
          <p>Help keep DivGaming maintained, updated, and useful for Division 2 players.</p>
          <div class="support-impact-grid">
            <span>Tool updates</span>
            <span>Build tracking</span>
            <span>Creator indexing</span>
            <span>Future features</span>
          </div>
        </div>
        <a href={coffeeUrl} target="_blank" rel="noopener">
          <Icon name="coffee" />
          Contribute Resources
        </a>
      </div>

      <div class="footer-bottom-row">
        <button id="install-btn" class="btn ghost install-btn" style="display:none">
          <Icon name="download" />
          <span>Add DivGaming to my device</span>
        </button>
        <a class="back-top" href="#top">Back to top ↑</a>
      </div>
    </div>
  </div>

  <div class="shell footer-dispatch-band" aria-label="Launch status">
    <div class="footer-dispatch-band__top">
      <div class="footer-dispatch-band__intro">
        <p class="eyebrow">Launch Status</p>
        <strong>Astro staging review</strong>
        <span>
          This version is being tightened for function, stability, production parity,
          mobile usability, and clean cutover readiness before replacing the live site.
        </span>
      </div>

      <div class="footer-dispatch-band__actions">
        <a href={withBase('/division-2/')}>Review Hub</a>
        <a href={withBase('/division-2/tools/')}>Check Tools</a>
      </div>
    </div>

    <div class="footer-dispatch-band__items">
      {dispatchItems.map((item) => (
        <div class="footer-dispatch-band__item">
          <span class="footer-dispatch-band__icon"><Icon name={item.icon} /></span>
          <div>
            <span class="footer-dispatch-band__label">{item.label}</span>
            <strong>{item.value}</strong>
            <p>{item.text}</p>
          </div>
        </div>
      ))}
    </div>
  </div>

  <style>
    .footer-social-card {
      display: grid;
      gap: 14px;
      border: 1px solid rgba(255, 107, 0, 0.22);
      border-radius: 22px;
      padding: 18px;
      background:
        radial-gradient(circle at top left, rgba(255, 107, 0, 0.11), transparent 42%),
        rgba(255, 255, 255, 0.028);
    }

    .footer-social-card .eyebrow {
      margin-bottom: 5px;
    }

    .footer-social-card strong {
      display: block;
      color: #fff;
      font-family: 'Chakra Petch', sans-serif;
      font-size: 1rem;
      line-height: 1.1;
    }

    .footer-actions .footer-socials {
      margin: 0;
    }

    .footer-dispatch-band {
      position: relative;
      z-index: 1;
      margin-top: 30px;
      border-top: 1px solid rgba(255, 107, 0, 0.22);
      border-bottom: 1px solid rgba(255, 107, 0, 0.22);
      padding: 20px 0;
    }

    .footer-dispatch-band__top {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 22px;
      align-items: end;
      margin-bottom: 16px;
    }

    .footer-dispatch-band__intro .eyebrow {
      margin-bottom: 5px;
    }

    .footer-dispatch-band__intro strong {
      display: block;
      color: #fff;
      font-family: 'Chakra Petch', sans-serif;
      font-size: 1.16rem;
      line-height: 1.1;
    }

    .footer-dispatch-band__intro span {
      display: block;
      max-width: 920px;
      margin-top: 7px;
      color: var(--muted);
      font-size: 0.92rem;
      line-height: 1.45;
    }

    .footer-dispatch-band__actions {
      display: flex;
      flex-wrap: wrap;
      justify-content: flex-end;
      gap: 9px;
    }

    .footer-dispatch-band__actions a {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 38px;
      border: 1px solid rgba(255, 107, 0, 0.3);
      border-radius: 999px;
      padding: 0 14px;
      color: rgba(217, 242, 238, 0.92);
      background: rgba(255, 107, 0, 0.055);
      font-family: 'Chakra Petch', sans-serif;
      font-size: 0.72rem;
      font-weight: 900;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      white-space: nowrap;
    }

    .footer-dispatch-band__actions a:hover {
      color: #160d05;
      background: var(--orange);
      border-color: var(--orange);
    }

    .footer-dispatch-band__items {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 10px;
    }

    .footer-dispatch-band__item {
      display: grid;
      grid-template-columns: auto minmax(0, 1fr);
      gap: 12px;
      align-items: start;
      min-height: 108px;
      border: 1px solid rgba(255, 107, 0, 0.16);
      border-radius: 16px;
      padding: 13px;
      background:
        radial-gradient(circle at top left, rgba(255, 107, 0, 0.085), transparent 45%),
        rgba(255, 255, 255, 0.025);
    }

    .footer-dispatch-band__icon {
      display: grid;
      place-items: center;
      width: 34px;
      height: 34px;
      border: 1px solid rgba(255, 107, 0, 0.24);
      border-radius: 12px;
      color: var(--orange-2);
      background: rgba(255, 107, 0, 0.075);
    }

    .footer-dispatch-band__icon .lucide-icon {
      width: 18px;
      height: 18px;
    }

    .footer-dispatch-band__label {
      display: block;
      color: var(--muted);
      font-family: 'Chakra Petch', sans-serif;
      font-size: 0.64rem;
      font-weight: 900;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      line-height: 1.2;
    }

    .footer-dispatch-band__item strong {
      display: block;
      margin-top: 4px;
      color: var(--green);
      font-family: 'Chakra Petch', sans-serif;
      font-size: 0.95rem;
      line-height: 1.15;
    }

    .footer-dispatch-band__item p {
      margin: 7px 0 0;
      color: var(--muted);
      font-size: 0.84rem;
      line-height: 1.38;
    }

    @media (max-width: 1120px) {
      .footer-dispatch-band__top {
        grid-template-columns: 1fr;
        align-items: start;
      }

      .footer-dispatch-band__actions {
        justify-content: flex-start;
      }

      .footer-dispatch-band__items {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 780px) {
      .footer-social-card {
        padding: 16px;
      }

      .footer-dispatch-band {
        margin-top: 24px;
        padding: 18px 0;
      }

      .footer-dispatch-band__top {
        gap: 14px;
        margin-bottom: 14px;
      }

      .footer-dispatch-band__intro strong {
        font-size: 1.04rem;
      }

      .footer-dispatch-band__intro span {
        font-size: 0.86rem;
      }

      .footer-dispatch-band__items {
        grid-template-columns: 1fr;
        gap: 9px;
      }

      .footer-dispatch-band__item {
        min-height: auto;
        border-radius: 14px;
        padding: 12px;
      }

      .footer-dispatch-band__item p {
        font-size: 0.82rem;
      }

      .footer-dispatch-band__actions {
        display: grid;
        grid-template-columns: 1fr 1fr;
        width: 100%;
      }

      .footer-dispatch-band__actions a {
        width: 100%;
      }
    }

    @media (max-width: 420px) {
      .footer-dispatch-band__actions {
        grid-template-columns: 1fr;
      }
    }
  </style>
</footer>
