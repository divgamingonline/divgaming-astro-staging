---
import {
  coreClass,
  coreLabel,
  itemBonuses,
  itemDescription,
  itemFilters,
  itemIcon,
  itemName,
  itemRoles,
  itemSearch,
  itemSource,
  itemSubhead,
  itemTalent,
  itemType,
  rarityClass,
  type ToolItem
} from '../utils/tools';

export interface Props { item: ToolItem; }
const { item } = Astro.props;
const icon = itemIcon(item);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const withBase = (href: string) => href.startsWith('http') ? href : `${base}${href}`;
const talent = itemTalent(item);
const bonuses = itemBonuses(item);
const roles = itemRoles(item);
const source = itemSource(item);
const description = itemDescription(item);
const core = coreLabel(item);
---

<article
  class:list={['tool-item-card', rarityClass(item)]}
  data-tool-card
  data-search={itemSearch(item)}
  data-filters={itemFilters(item)}
>
  <div class="item-top">
    {icon && <img class="item-icon" src={withBase(icon)} alt="" loading="lazy" />}
    <div>
      <p class="eyebrow">{itemType(item)}</p>
      <h3>{itemName(item)}</h3>
      {itemSubhead(item) && <p class="item-subhead">{itemSubhead(item)}</p>}
    </div>
  </div>

  {core && <span class:list={['core-badge', coreClass(item)]}><i></i>{core}</span>}

  {talent ? (
    <div class="talent-box">
      {talent.name && <strong>{talent.name}</strong>}
      {talent.description && <p>{talent.description}</p>}
    </div>
  ) : description && <p class="item-description">{description}</p>}

  {bonuses.length > 0 && (
    <ul class="bonus-list">
      {bonuses.slice(0, 5).map((bonus) => <li>{bonus}</li>)}
    </ul>
  )}

  {roles.length > 0 && (
    <div class="chip-row">
      {roles.slice(0, 5).map((role) => <span>{role}</span>)}
    </div>
  )}

  {source && <p class="source-line"><strong>Source:</strong> {source}</p>}
</article>
