---
import {
  coreClass,
  coreLabel,
  itemBonuses,
  itemDescription,
  itemFilters,
  itemIcon,
  itemName,
  itemNamedAttributes,
  itemRoles,
  itemSearch,
  itemSource,
  itemSubhead,
  itemTalent,
  itemType,
  rarityClass,
  type ToolItem
} from '../utils/tools';

export interface Props { item: ToolItem; }
const { item } = Astro.props;
const icon = itemIcon(item);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const withBase = (href: string) => href.startsWith('http') ? href : `${base}${href}`;
const talent = itemTalent(item);
const namedAttributes = itemNamedAttributes(item);
const bonuses = itemBonuses(item);
const roles = itemRoles(item);
const source = itemSource(item);
const description = itemDescription(item);
const core = coreLabel(item);
---

<article
  class:list={['tool-item-card', rarityClass(item)]}
  data-tool-card
  data-search={itemSearch(item)}
  data-filters={itemFilters(item)}
>
  <div class="item-top">
    {icon && <img class="item-icon" src={withBase(icon)} alt="" loading="lazy" />}
    <div>
      <p class="eyebrow">{itemType(item)}</p>
      <h3>{itemName(item)}</h3>
      {itemSubhead(item) && <p class="item-subhead">{itemSubhead(item)}</p>}
    </div>
  </div>

  {core && <span class:list={['core-badge', coreClass(item)]}><i></i>{core}</span>}

  {talent ? (
    <div class="talent-box talent-box--compare">
      <div class="talent-section talent-section--perfect">
        <span class="talent-label">Perfect Talent</span>
        <strong>{talent.perfectName}</strong>
        <p>{talent.perfectDescription}</p>
      </div>

      <div class="talent-section">
        <span class="talent-label">Regular Talent</span>
        <strong>{talent.regularName}</strong>
        <p>{talent.regularDescription}</p>
      </div>

      <p class="talent-difference"><strong>Perfect difference:</strong> {talent.difference}</p>
    </div>
  ) : description && (
    <p class="item-description">{description}</p>
  )}

  {namedAttributes.length > 0 && (
    <div class="named-attribute-box">
      <span class="talent-label">Named Attribute</span>
      <ul class="bonus-list">
        {namedAttributes.map((property) => (
          <li>
            <strong>{property.label}</strong>
            {property.description && <span> — {property.description}</span>}
          </li>
        ))}
      </ul>
    </div>
  )}

  {bonuses.length > 0 && (
    <ul class="bonus-list">
      {bonuses.slice(0, 5).map((bonus) => <li>{bonus}</li>)}
    </ul>
  )}

  {roles.length > 0 && (
    <div class="chip-row">
      {roles.slice(0, 5).map((role) => <span>{role}</span>)}
    </div>
  )}

  {source && <p class="source-line"><strong>Source:</strong> {source}</p>}
</article>

<style>
  .talent-box--compare {
    display: grid;
    gap: 12px;
  }

  .talent-section {
    border-top: 1px solid rgba(255, 255, 255, .08);
    padding-top: 10px;
  }

  .talent-section:first-child {
    border-top: 0;
    padding-top: 0;
  }

  .talent-label {
    display: block;
    color: var(--orange2);
    font-family: "Chakra Petch", sans-serif;
    font-size: .68rem;
    font-weight: 800;
    letter-spacing: .14em;
    text-transform: uppercase;
    margin-bottom: 5px;
  }

  .talent-section strong {
    display: block;
    color: #fff;
    margin-bottom: 4px;
  }

  .talent-difference {
    border-top: 1px solid rgba(255, 107, 0, .22);
    margin: 0;
    padding-top: 10px;
  }

  .named-attribute-box {
    border: 1px solid rgba(255, 107, 0, .18);
    border-radius: 14px;
    padding: 12px;
    background: rgba(255, 107, 0, .045);
  }

  .named-attribute-box .bonus-list {
    margin-top: 6px;
  }
</style>
