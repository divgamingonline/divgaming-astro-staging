---
import {
  confidenceLabel,
  displayName,
  itemBonuses,
  itemDescription,
  itemFilterTokens,
  itemRoles,
  itemSearchText,
  itemSource,
  itemSubhead,
  itemTalent,
  itemTypeLabel,
  type ToolDataItem
} from '../utils/division2Tools';

export interface Props {
  item: ToolDataItem;
  compact?: boolean;
}

const { item, compact = false } = Astro.props;

const name = displayName(item);
const type = itemTypeLabel(item);
const subhead = itemSubhead(item);
const talent = itemTalent(item);
const bonuses = itemBonuses(item);
const roles = itemRoles(item);
const source = itemSource(item);
const description = itemDescription(item);
const confidence = confidenceLabel(item);
const searchText = itemSearchText(item);
const filters = itemFilterTokens(item).join(' ');

function assetSlug(value: unknown): string {
  return String(value || '')
    .normalize('NFD')
    .replace(/[\u0300-\u036f]/g, '')
    .toLowerCase()
    .replace(/['’]/g, '')
    .replace(/&/g, 'and')
    .replace(/[^a-z0-9]+/g, '')
    .trim();
}

function gearSlug(value: unknown): string {
  const slot = String(value || '').toLowerCase();
  if (slot.includes('backpack')) return 'backpack';
  if (slot.includes('chest') || slot.includes('vest')) return 'chest';
  if (slot.includes('glove')) return 'gloves';
  if (slot.includes('holster')) return 'holster';
  if (slot.includes('knee')) return 'kneepads';
  if (slot.includes('mask')) return 'mask';
  return '';
}

function weaponSlug(value: unknown): string {
  const weapon = String(value || '').toLowerCase();
  if (weapon.includes('smg')) return 'smg';
  if (weapon.includes('lmg')) return 'lmg';
  if (weapon.includes('mmr') || weapon.includes('marksman')) return 'mmr';
  if (weapon.includes('rifle') && !weapon.includes('assault')) return 'rifle';
  if (weapon.includes('shotgun')) return 'shotgun';
  if (weapon.includes('pistol') || weapon.includes('sidearm')) return 'pistol';
  if (weapon.includes('ar') || weapon.includes('assault')) return 'ar';
  return '';
}

function normalizedType(item: ToolDataItem): string {
  const text = `${item.rarity || ''} ${item.category || ''} ${item.itemType || ''}`.toLowerCase();
  if (text.includes('exotic')) return 'exotic';
  if (text.includes('gear set') || text.includes('gearset')) return 'gear-set';
  if (text.includes('brand set')) return 'brand-set';
  if (text.includes('named')) return 'named';
  return 'standard';
}

const rarityType = normalizedType(item);
const coreValue = String(item.defaultCore || item.cores?.[0] || item.availableCores?.[0] || item.coreRollLabel || '').toLowerCase();

const coreClass =
  coreValue.includes('weapon') ? 'core-red' :
  coreValue.includes('armor') ? 'core-blue' :
  coreValue.includes('skill') ? 'core-yellow' :
  '';

const coreLabel =
  coreValue.includes('weapon') ? 'Weapon Damage' :
  coreValue.includes('armor') ? 'Armor' :
  coreValue.includes('skill') ? 'Skill Tier' :
  String(item.coreRollLabel || item.coreRollText || '').replace(/^Core attributes?:\s*/i, '').replace(/\.$/, '');

const brandAssetKey = String(item.assetKey || assetSlug(item.brandOrSet || item.brand || item.set || item.name));
const slotAssetKey = gearSlug(item.slot);
const weaponAssetKey = weaponSlug(item.weaponType);

const canUseBrandIcon = Boolean(brandAssetKey) && ['brand-set', 'gear-set'].includes(rarityType);
const canUseNamedBrandIcon = Boolean(brandAssetKey) && rarityType === 'named' && !['weapon', 'namedweapon'].includes(brandAssetKey);
const showBrandIcon = canUseBrandIcon || canUseNamedBrandIcon;
const showSlotIcon = Boolean(slotAssetKey) && !showBrandIcon;
const showWeaponIcon = Boolean(weaponAssetKey) && !showBrandIcon && !showSlotIcon;

const primaryIcon =
  showBrandIcon ? `/assets/division-2/icons/brands/${brandAssetKey}.png` :
  showSlotIcon ? `/assets/division-2/icons/gears/${slotAssetKey}.png` :
  showWeaponIcon ? `/assets/division-2/icons/weapons/${weaponAssetKey}.png` :
  '';

const fallbackIcon =
  showBrandIcon ? '/assets/division-2/icons/brands/_blank.png' :
  showSlotIcon ? '/assets/division-2/icons/gears/_blank.png' :
  showWeaponIcon ? '/assets/division-2/icons/weapons/_blank.png' :
  '';

const cardClass = `rarity-${rarityType}`;
---

<article
  class:list={['tool-item-card', 'card', cardClass, compact && 'tool-item-card--compact']}
  data-tool-card
  data-search={searchText}
  data-filters={filters}
>
  <div class="tool-item-card__top">
    <div class="tool-item-card__title-row">
      {primaryIcon && (
        <span class="codex-logo-wrap">
          <img
            class="codex-logo"
            src={primaryIcon}
            alt=""
            loading="lazy"
            onerror={`this.src='${fallbackIcon}'`}
          />
        </span>
      )}
      <div>
        <p class="mission-kicker">{type}</p>
        <h3>{name}</h3>
        {subhead && <p class="tool-item-card__subhead">{subhead}</p>}
      </div>
    </div>
    {confidence && <span class="tool-item-card__confidence">{confidence}</span>}
  </div>

  {coreLabel && (
    <div class:list={['core-badge', coreClass]}>
      <span class="core-dot"></span>
      {coreLabel}
    </div>
  )}

  {talent && (
    <div class="tool-item-card__talent">
      {talent.name && <strong>{talent.name}</strong>}
      {talent.description && <p>{talent.description}</p>}
    </div>
  )}

  {!talent && description && (
    <p class="tool-item-card__description">{description}</p>
  )}

  {bonuses.length > 0 && (
    <ul class="tool-item-card__list">
      {bonuses.slice(0, compact ? 3 : 5).map((bonus) => (
        <li>{bonus}</li>
      ))}
    </ul>
  )}

  {roles.length > 0 && (
    <div class="badge-row tool-item-card__chips">
      {roles.slice(0, 5).map((role) => (
        <span>{role}</span>
      ))}
    </div>
  )}

  {source && (
    <p class="tool-item-card__source">
      <strong>Source:</strong> {source}
    </p>
  )}
</article>
