---
import {
  confidenceLabel,
  displayName,
  itemBonuses,
  itemDescription,
  itemFilterTokens,
  itemRoles,
  itemSearchText,
  itemSource,
  itemSubhead,
  itemTalent,
  itemTypeLabel,
  type ToolDataItem
} from '../utils/division2Tools';

export interface Props {
  item: ToolDataItem;
  compact?: boolean;
}

const { item, compact = false } = Astro.props;

const name = displayName(item);
const type = itemTypeLabel(item);
const subhead = itemSubhead(item);
const talent = itemTalent(item);
const bonuses = itemBonuses(item);
const roles = itemRoles(item);
const source = itemSource(item);
const description = itemDescription(item);
const confidence = confidenceLabel(item);
const searchText = itemSearchText(item);
const filters = itemFilterTokens(item).join(' ');
---

<article
  class:list={['tool-item-card', 'card', compact && 'tool-item-card--compact']}
  data-tool-card
  data-search={searchText}
  data-filters={filters}
>
  <div class="tool-item-card__top">
    <div>
      <p class="mission-kicker">{type}</p>
      <h3>{name}</h3>
      {subhead && <p class="tool-item-card__subhead">{subhead}</p>}
    </div>
    {confidence && <span class="tool-item-card__confidence">{confidence}</span>}
  </div>

  {talent && (
    <div class="tool-item-card__talent">
      {talent.name && <strong>{talent.name}</strong>}
      {talent.description && <p>{talent.description}</p>}
    </div>
  )}

  {!talent && description && (
    <p class="tool-item-card__description">{description}</p>
  )}

  {bonuses.length > 0 && (
    <ul class="tool-item-card__list">
      {bonuses.slice(0, compact ? 3 : 5).map((bonus) => (
        <li>{bonus}</li>
      ))}
    </ul>
  )}

  {roles.length > 0 && (
    <div class="badge-row tool-item-card__chips">
      {roles.slice(0, 5).map((role) => (
        <span>{role}</span>
      ))}
    </div>
  )}

  {source && (
    <p class="tool-item-card__source">
      <strong>Source:</strong> {source}
    </p>
  )}
</article>

<style>
  .tool-item-card {
    display: flex;
    flex-direction: column;
    gap: 14px;
    padding: 18px;
    min-height: 100%;
  }

  .tool-item-card[hidden] {
    display: none;
  }

  .tool-item-card__top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 14px;
  }

  .tool-item-card h3 {
    margin: 0;
    color: #fff;
    font-family: 'Chakra Petch', sans-serif;
    font-size: 1.25rem;
    letter-spacing: -0.015em;
    line-height: 1.12;
  }

  .tool-item-card__subhead,
  .tool-item-card__description,
  .tool-item-card__source,
  .tool-item-card__talent p {
    color: var(--muted);
  }

  .tool-item-card__subhead {
    margin: 6px 0 0;
    font-size: 0.9rem;
  }

  .tool-item-card__confidence {
    flex: 0 0 auto;
    border: 1px solid rgba(255, 107, 0, 0.32);
    border-radius: 999px;
    padding: 5px 8px;
    color: var(--orange-2);
    background: rgba(255, 107, 0, 0.09);
    font-family: 'Chakra Petch', sans-serif;
    font-size: 0.66rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .tool-item-card__talent {
    border: 1px solid rgba(255, 107, 0, 0.18);
    border-radius: 14px;
    padding: 12px;
    background: rgba(255, 107, 0, 0.06);
  }

  .tool-item-card__talent strong {
    color: var(--orange-2);
    font-family: 'Chakra Petch', sans-serif;
  }

  .tool-item-card__talent p,
  .tool-item-card__description,
  .tool-item-card__source {
    margin: 6px 0 0;
    line-height: 1.45;
  }

  .tool-item-card__list {
    margin: 0;
    padding-left: 18px;
    color: var(--muted);
  }

  .tool-item-card__list li + li {
    margin-top: 5px;
  }

  .tool-item-card__chips {
    margin-top: auto;
    padding: 0;
    border: 0;
    background: transparent;
  }

  .tool-item-card__source {
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    padding-top: 12px;
    font-size: 0.9rem;
  }

  .tool-item-card--compact .tool-item-card__source {
    display: none;
  }
</style>
