---
import Icon from './Icon.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const withBase = (href: string) => href.startsWith('http') ? href : `${base}${href}`;

const tabs = [
  ['Home', '/', 'home'],
  ['Builds', '/division-2/builds/', 'builds'],
  ['Tools', '/division-2/tools/', 'tools'],
  ['Saved', '/division-2/saved/', 'save'],
  ['Videos', '/division-2/videos/', 'videos']
];
---

<nav class="mobile-tabbar" aria-label="Mobile navigation">
  {tabs.map(([label, href, icon]) => (
    <a href={withBase(href)}>
      <Icon name={icon} />
      <span>{label}</span>
    </a>
  ))}
</nav>
