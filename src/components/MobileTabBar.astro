---
import Icon from './Icon.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

function withBase(href: string) {
  if (href.startsWith('http')) return href;
  return `${base}${href}`;
}

const mobileTabs = [
  { label: 'Home', href: '/', icon: 'home' },
  { label: 'Builds', href: '/division-2/builds/', icon: 'crosshair' },
  { label: 'Tools', href: '/division-2/tools/', icon: 'backpack' },
  { label: 'Videos', href: '/division-2/videos/', icon: 'video' },
  { label: 'Hub', href: '/division-2/', icon: 'route' }
];
---

<nav class="mobile-tabbar" aria-label="Mobile navigation">
  {mobileTabs.map((item) => (
    <a href={withBase(item.href)}>
      <Icon name={item.icon} />
      <strong>{item.label}</strong>
    </a>
  ))}
</nav>
