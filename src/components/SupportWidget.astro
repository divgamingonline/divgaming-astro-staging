---
import Icon from './Icon.astro';
const coffeeUrl = 'https://buymeacoffee.com/divgamingoy';
---

<div class="mobile-coffee">
  <button type="button" data-coffee-open aria-label="Support DivGaming"><Icon name="coffee" /></button>
</div>

<div class="coffee-overlay" data-coffee-overlay></div>

<section class="coffee-sheet" data-coffee-sheet>
  <div class="coffee-sheet-head">
    <strong>Support DivGaming</strong>
    <button type="button" data-coffee-close>×</button>
  </div>
  <p>Your support helps keep DivGaming maintained, updated, and useful for Division 2 players.</p>
  <a class="button primary" href={coffeeUrl} target="_blank" rel="noopener">
    <Icon name="coffee" />
    Buy me a coffee
  </a>
</section>

<script>
  const open = document.querySelector('[data-coffee-open]');
  const close = document.querySelector('[data-coffee-close]');
  const overlay = document.querySelector('[data-coffee-overlay]');
  const sheet = document.querySelector('[data-coffee-sheet]');

  function show() {
    overlay?.classList.add('is-open');
    sheet?.classList.add('is-open');
  }

  function hide() {
    overlay?.classList.remove('is-open');
    sheet?.classList.remove('is-open');
  }

  open?.addEventListener('click', show);
  close?.addEventListener('click', hide);
  overlay?.addEventListener('click', hide);
</script>
