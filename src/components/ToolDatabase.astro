---
import ToolItemCard from './ToolItemCard.astro';
import { getItems, itemFilters } from '../utils/tools';

export interface Props {
  data: any;
  eyebrow: string;
  title: string;
  description: string;
}

const { data, eyebrow, title, description } = Astro.props;
const items = getItems(data);

const filterLabels: Record<string, string> = {
  all: 'All',
  exotic: 'Exotic',
  named: 'Named',
  brandset: 'Brand Set',
  gearset: 'Gear Set',
  gear: 'Gear',
  weapon: 'Weapon',
  talent: 'Talent',
  prototype: 'Prototype',
  backpack: 'Backpack',
  chest: 'Chest',
  mask: 'Mask',
  gloves: 'Gloves',
  holster: 'Holster',
  kneepads: 'Kneepads',
  weapon_damage: 'Weapon Damage Core',
  armor_core: 'Armor Core',
  skill_tier: 'Skill Tier',
  ar: 'Assault Rifle',
  rifle: 'Rifle',
  smg: 'SMG',
  lmg: 'LMG',
  shotgun: 'Shotgun',
  mmr: 'Marksman Rifle',
  pistol: 'Pistol'
};

const preferredOrder = [
  'all',
  'gear',
  'weapon',
  'talent',
  'prototype',
  'backpack',
  'chest',
  'mask',
  'gloves',
  'holster',
  'kneepads',
  'weapon_damage',
  'armor_core',
  'skill_tier',
  'ar',
  'rifle',
  'smg',
  'lmg',
  'shotgun',
  'mmr',
  'pistol',
  'exotic',
  'named',
  'brandset',
  'gearset'
];

const filterCounts = new Map<string, number>();
filterCounts.set('all', items.length);

for (const item of items) {
  const filters = new Set(itemFilters(item).split(/\s+/).filter(Boolean));

  for (const filter of filters) {
    if (filter === 'all') continue;
    filterCounts.set(filter, (filterCounts.get(filter) || 0) + 1);
  }
}

const discoveredFilters = [...filterCounts.keys()]
  .filter((filter) => filter !== 'all')
  .sort((a, b) => {
    const ai = preferredOrder.includes(a) ? preferredOrder.indexOf(a) : 999;
    const bi = preferredOrder.includes(b) ? preferredOrder.indexOf(b) : 999;
    if (ai !== bi) return ai - bi;
    return a.localeCompare(b);
  });

const activeFilters = [
  {
    key: 'all',
    label: filterLabels.all,
    count: items.length
  },
  ...discoveredFilters
    .filter((filter) => {
      const count = filterCounts.get(filter) || 0;

      // Hide filters that are empty or identical to the whole current page.
      // Example: Named Items Database should not show Named 60/60.
      return count > 0 && count < items.length;
    })
    .map((filter) => ({
      key: filter,
      label: filterLabels[filter] || filter.replace(/^role_/, '').replace(/_/g, ' '),
      count: filterCounts.get(filter) || 0
    }))
];
---

<section class="shell hero compact-hero">
  <div class="page-hero">
    <div>
      <p class="eyebrow">{eyebrow}</p>
      <h1>{title}</h1>
      <p class="lead">{description}</p>
    </div>
    <aside class="hero-panel">
      <span>Records</span>
      <strong>{items.length}</strong>
      <small>Searchable entries</small>
    </aside>
  </div>
</section>

<section class="shell section" data-tool-database>
  <div class="section-head">
    <p class="eyebrow">Searchable database</p>
    <h2><span data-tool-count>{items.length}</span> entries</h2>
    <p>Search by name, slot, item type, talent, role, or keyword.</p>
  </div>

  <div class="filter-panel">
    <input type="search" placeholder="Search this database..." data-tool-search />
    <button type="button" data-tool-filter-toggle>Filters</button>
    <button type="button" data-tool-reset>Reset</button>
    <div class="filter-buttons" data-tool-filters>
      {activeFilters.map((filter) => (
        <button
          type="button"
          class={filter.key === 'all' ? 'active' : ''}
          data-filter={filter.key}
          title={`${filter.count} matching entries`}
        >
          {filter.label}
          <span>{filter.count}</span>
        </button>
      ))}
    </div>
  </div>

  <div class="tool-grid">
    {items.map((item) => <ToolItemCard item={item} />)}
  </div>

  <div class="empty-state" data-tool-empty hidden>
    <h2>No matching entries found.</h2>
    <p>Try a broader search term or reset the filters.</p>
  </div>
</section>

<script>
  for (const root of document.querySelectorAll('[data-tool-database]')) {
    const input = root.querySelector('[data-tool-search]');
    const cards = [...root.querySelectorAll('[data-tool-card]')];
    const buttons = [...root.querySelectorAll('[data-filter]')];
    const count = root.querySelector('[data-tool-count]');
    const empty = root.querySelector('[data-tool-empty]');
    const reset = root.querySelector('[data-tool-reset]');
    const filterPanel = root.querySelector('[data-tool-filters]');
    const filterToggle = root.querySelector('[data-tool-filter-toggle]');
    let active = 'all';

    function closeMobileFilters() {
      if (window.matchMedia('(max-width: 780px)').matches) {
        filterPanel?.classList.remove('is-open');
      }
    }

    function cardHasFilter(card, filter) {
      if (filter === 'all') return true;
      const filters = (card.dataset.filters || '').split(/\s+/).filter(Boolean);
      return filters.includes(filter);
    }

    function apply() {
      const q = (input?.value || '').toLowerCase().trim();
      let visible = 0;

      for (const card of cards) {
        const search = card.dataset.search || '';
        const okSearch = !q || search.includes(q);
        const okFilter = cardHasFilter(card, active);
        const show = okSearch && okFilter;
        card.hidden = !show;
        if (show) visible++;
      }

      count.textContent = String(visible);
      empty.hidden = visible !== 0;
    }

    input?.addEventListener('input', apply);
    filterToggle?.addEventListener('click', () => filterPanel?.classList.toggle('is-open'));

    for (const button of buttons) {
      button.addEventListener('click', () => {
        active = button.dataset.filter || 'all';
        buttons.forEach((item) => item.classList.toggle('active', item === button));
        apply();
        closeMobileFilters();
      });
    }

    reset?.addEventListener('click', () => {
      if (input) input.value = '';
      active = 'all';
      buttons.forEach((item) => item.classList.toggle('active', item.dataset.filter === 'all'));
      apply();
      closeMobileFilters();
    });
  }
</script>
