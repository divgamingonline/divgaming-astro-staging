---
import BaseLayout from '../layouts/BaseLayout.astro';
import BuildGrid from './BuildGrid.astro';
import {
  BUILD_CATEGORIES,
  getBuildVideos,
  type BuildCategoryKey
} from '../utils/builds';

export interface Props {
  data: unknown;
  category: BuildCategoryKey;
}

const { data, category } = Astro.props;
const config = BUILD_CATEGORIES[category];
const videos = getBuildVideos(data, category);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout
  title={`${config.label} | DivGaming Astro Staging`}
  description={config.description}
  canonical={config.canonical}
  noindex={true}
>
  <section class="shell hero">
    <div class="hub-hero">
      <p class="eyebrow">Build Discovery</p>
      <h1>{config.label}</h1>
      <p class="lead">{config.description}</p>
      <div class="hero-actions">
        <a class="button" href={`${base}/division-2/builds/`}>All builds</a>
        <a class="button button--ghost" href={`${base}/division-2/videos/`}>Video library</a>
      </div>
    </div>
  </section>

  <section class="shell section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Creator videos</p>
        <h2>{videos.length} videos</h2>
      </div>
      <p>
        Search by creator, title, build tag, activity, or role. Watching still
        happens directly on YouTube.
      </p>
    </div>

    <BuildGrid videos={videos} />
  </section>
</BaseLayout>
