---
import BaseLayout from '../layouts/BaseLayout.astro';
import BuildGrid from './BuildGrid.astro';
import {
  BUILD_CATEGORIES,
  getBuildVideos,
  type BuildCategoryKey
} from '../utils/builds';

export interface Props {
  data: unknown;
  category: BuildCategoryKey;
}

const { data, category } = Astro.props;
const config = BUILD_CATEGORIES[category];
const videos = getBuildVideos(data, category);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout
  title={`${config.label} | DivGaming`}
  description={config.description}
  canonical={config.canonical}
  noindex={true}
>
  <section class="shell hero">
    <div class="command-hero">
      <div>
        <p class="eyebrow">Build Library</p>
        <h1>{config.label}</h1>
        <p class="lead">{config.description}</p>
        <div class="hero-actions">
          <a class="btn primary" href={`${base}/division-2/builds/`}>All Builds</a>
          <a class="btn ghost" href={`${base}/division-2/videos/`}>Video Library</a>
        </div>
      </div>

      <aside class="command-panel">
        <p class="eyebrow">Build index</p>
        <div class="command-panel__list">
          <div class="command-panel__row"><span>Videos</span><strong>{videos.length}</strong></div>
          <div class="command-panel__row"><span>Playback</span><strong>YouTube</strong></div>
        </div>
      </aside>
    </div>
  </section>

  <section class="shell section">
    <div class="section-head">
      <p class="eyebrow">Creator videos</p>
      <h2>{videos.length} videos</h2>
      <p>
        Search by creator, title, build tag, activity, or role. Watching still
        happens directly on YouTube so creators receive the visit.
      </p>
    </div>

    <BuildGrid videos={videos} />
  </section>
</BaseLayout>
