---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  image?: string;
  noindex?: boolean;
}

const {
  title = 'DivGaming | Division 2 Community Hub',
  description = 'DivGaming is an unofficial Division 2 community hub for builds, tools, guides, videos, and creator resources.',
  canonical = '/',
  image = '/assets/img/divgaming-og.svg',
  noindex = false
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const canonicalPath = canonical.startsWith('/') ? canonical : `/${canonical}`;
const canonicalUrl = `https://divgaming.com${canonicalPath}`;
const siteImage = image.startsWith('http') ? image : `${base}${image}`;
const navItems = [
  { label: 'Home', href: '/' },
  { label: 'Division 2', href: '/division-2/' },
  { label: 'Builds', href: '/division-2/builds/' },
  { label: 'Tools', href: '/division-2/tools/' },
  { label: 'Videos', href: '/division-2/videos/' }
];

function withBase(href: string) {
  if (href.startsWith('http')) return href;
  return `${base}${href}`;
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="DivGaming" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={siteImage} />
    <meta property="og:url" content={canonicalUrl} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={siteImage} />

    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
    <link rel="manifest" href={withBase('/manifest.json')} />
    <title>{title}</title>
  </head>

  <body>
    <div class="site-bg" aria-hidden="true">
      <span class="site-bg__grid"></span>
      <span class="site-bg__orb site-bg__orb--one"></span>
      <span class="site-bg__orb site-bg__orb--two"></span>
    </div>

    <header class="site-header">
      <a class="site-brand" href={withBase('/')} aria-label="DivGaming home">
        <span class="site-brand__mark">D</span>
        <span class="site-brand__text">
          <strong>DIVGAMING</strong>
          <small>Division 2 Field Hub</small>
        </span>
      </a>

      <nav class="site-nav" aria-label="Primary navigation">
        {navItems.map((item) => (
          <a href={withBase(item.href)}>{item.label}</a>
        ))}
      </nav>

      <a class="site-header__cta" href={withBase('/division-2/tools/')}>Field Tools</a>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="shell site-footer__inner">
        <div>
          <p class="eyebrow">Unofficial Community Project</p>
          <strong>DivGaming</strong>
          <p>
            Built for Division agents who need builds, tools, references, and
            creator discovery in one clean hub.
          </p>
        </div>

        <div class="site-footer__links">
          <a href={withBase('/division-2/builds/')}>Builds</a>
          <a href={withBase('/division-2/tools/')}>Tools</a>
          <a href={withBase('/division-2/videos/')}>Videos</a>
          <a href={withBase('/division-2/')}>Division 2 Hub</a>
        </div>
      </div>
    </footer>
  </body>
</html>
