---
import '../styles/global.css';
import buildsData from '../../data/builds.json';
import exoticsData from '../../data/division-2/exotics.json';
import namedItemsData from '../../data/division-2/named-items.json';
import brandsetsData from '../../data/division-2/brandsets.json';
import gearsetsData from '../../data/division-2/gearsets.json';
import gearTalentsData from '../../data/division-2/gear-talents.json';
import weaponTalentsData from '../../data/division-2/weapon-talents.json';

import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import MobileTabBar from '../components/MobileTabBar.astro';
import SupportWidget from '../components/SupportWidget.astro';
import { getVideos } from '../utils/videos';
import { getItems } from '../utils/tools';

export interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  noindex?: boolean;
}

const {
  title = 'DivGaming | Division 2 Builds, Tools, Guides & Community Resources',
  description = 'DivGaming is a Division 2 community hub for builds, gear tools, creator videos, guides, and player-friendly references.',
  canonical = '/',
  noindex = true
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const canonicalUrl = `https://divgaming.com${canonical.startsWith('/') ? canonical : `/${canonical}`}`;
const records =
  getItems(exoticsData).length +
  getItems(namedItemsData).length +
  getItems(brandsetsData).length +
  getItems(gearsetsData).length +
  getItems(gearTalentsData).length +
  getItems(weaponTalentsData).length;
const videos = getVideos(buildsData);
const creatorCount = new Set(videos.map((video) => video.creator || video.channelTitle).filter(Boolean)).size;
---

<!doctype html>
<html lang="en-US" translate="no" class="notranslate">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="content-language" content="en-US" />
    <meta name="google" content="notranslate" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta name="robots" content={noindex ? 'noindex,nofollow' : 'index,follow'} />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="DivGaming" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${base}/assets/img/og-image.jpg`} />

    <link rel="manifest" href={`${base}/site.webmanifest`} />
    <link rel="icon" href={`${base}/favicon.svg`} />
    <link rel="apple-touch-icon" href={`${base}/assets/img/dg-icon-192.png`} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Chakra+Petch:wght@400;600;700&family=Barlow:wght@400;500;600;700&display=swap" />

    <title>{title}</title>
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <SupportWidget />
    <MobileTabBar />
    <Footer videos={videos.length} creators={creatorCount} records={records} />
  </body>
</html>
