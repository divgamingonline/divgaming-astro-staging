---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  image?: string;
  noindex?: boolean;
}

const {
  title = 'DivGaming | The Division 2 Builds, Guides, Tools & Community',
  description = 'DivGaming is an unofficial The Division 2 community hub for builds, guides, tools, creators, vendor reset tracking, named items, and exotic sources.',
  canonical = Astro.url.pathname,
  image = '/assets/img/divgaming-og.svg',
  noindex = false
} = Astro.props;

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://divgamingonline.github.io';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const canonicalUrl = canonical.startsWith('http')
  ? canonical
  : `${siteUrl}${base}${canonical.startsWith('/') ? canonical : `/${canonical}`}`;
const imageUrl = image.startsWith('http')
  ? image
  : `${siteUrl}${base}${image.startsWith('/') ? image : `/${image}`}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {noindex ? <meta name="robots" content="noindex, nofollow" /> : <meta name="robots" content="index, follow, max-image-preview:large" />}
    <meta property="og:site_name" content="DivGaming" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <link rel="manifest" href={`${base}/manifest.json`} />
    <link rel="icon" href={`${base}/favicon.svg`} />
    <slot name="head" />
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <header class="site-header">
      <div class="shell site-header__inner">
        <a class="logo" href={`${base}/`} aria-label="DivGaming home"><span class="logo-mark">D</span><span>DIVGAMING</span></a>
        <nav class="main-nav" aria-label="Primary navigation">
          <a href={`${base}/`}>Home</a>
          <a href={`${base}/division-2/`}>Division 2 Hub</a>
          <a href={`${base}/division-2/builds/`}>Builds</a>
          <a href={`${base}/division-2/tools/`}>Tools</a>
          <a href={`${base}/division-2/creators/`}>Creators</a>
        </nav>
      </div>
    </header>
    <main id="main-content" class="page"><slot /></main>
    <footer class="site-footer">
      <div class="shell">
        <p>DivGaming.com is an unofficial community project and is not affiliated with Ubisoft or Massive Entertainment.</p>
        <p class="footer-links"><a href={`${base}/division-2/`}>Division 2 Hub</a><a href={`${base}/division-2/tools/`}>Tools</a><a href={`${base}/division-2/builds/`}>Builds</a></p>
      </div>
    </footer>
  </body>
</html>
