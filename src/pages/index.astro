---
import BaseLayout from '../layouts/BaseLayout.astro';
import buildsData from '../../data/builds.json';
import exoticsData from '../../data/division-2/exotics.json';
import namedItemsData from '../../data/division-2/named-items.json';
import { getVideos } from '../utils/videos';
import { getItems } from '../utils/tools';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const videos = getVideos(buildsData);
const exotics = getItems(exoticsData);
const named = getItems(namedItemsData);
---

<BaseLayout canonical="/">
  <section class="home-hero">
    <div class="shell hero-grid">
      <div>
        <img class="division-logo" src={`${base}/assets/img/division2-logo-white-2-1086.webp`} alt="Tom Clancy's The Division 2" />
        <p class="eyebrow">DivGaming // SHD Intel // Community</p>
        <h1>SHD Agent Companion</h1>
        <p class="lead">
          The Division 2 build, item, gear, talent, prototype, vendor, creator, and field-intel hub for agents who want answers fast.
        </p>
        <div class="hero-actions">
          <a class="button primary" href={`${base}/division-2/builds/`}>Browse Builds</a>
          <a class="button ghost" href={`${base}/division-2/tools/`}>Open Tools</a>
          <a class="button ghost" href={`${base}/division-2/saved/`}>Saved Builds</a>
        </div>
      </div>

      <aside class="hero-stats">
        <a href={`${base}/division-2/tools/`}><strong>8</strong><span>Tools Available</span></a>
        <a href={`${base}/division-2/videos/`}><strong>{videos.length}</strong><span>Videos Indexed</span></a>
        <a href={`${base}/division-2/tools/exotic-source-tracker/`}><strong>{exotics.length}</strong><span>Exotics</span></a>
        <a href={`${base}/division-2/tools/named-items-database/`}><strong>{named.length}</strong><span>Named Items</span></a>
      </aside>
    </div>
  </section>

  <section class="shell section">
    <div class="section-head">
      <p class="eyebrow">Start Here</p>
      <h2>What are you looking for?</h2>
      <p>Choose the path that matches what you need right now.</p>
    </div>

    <div class="feature-grid">
      <a class="feature-card primary-card" href={`${base}/division-2/builds/`}>
        <span>Builds</span>
        <strong>Find a Build</strong>
        <p>Browse PvE, PvP, solo, Striker, and creator build videos.</p>
      </a>
      <a class="feature-card" href={`${base}/division-2/tools/`}>
        <span>Tools</span>
        <strong>Research Gear</strong>
        <p>Look up exotics, named items, brand sets, gearsets, talents, prototype eligibility, and vendor routes.</p>
      </a>
      <a class="feature-card" href={`${base}/division-2/saved/`}>
        <span>Saved</span>
        <strong>Save Builds</strong>
        <p>Save builds locally in your browser so you can reference them later.</p>
      </a>
      <a class="feature-card" href={`${base}/division-2/creators/`}>
        <span>Creators</span>
        <strong>Find Creator Videos</strong>
        <p>Discover content and open videos directly on YouTube.</p>
      </a>
    </div>
  </section>
</BaseLayout>
