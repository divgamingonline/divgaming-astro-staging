---
import BaseLayout from '../layouts/BaseLayout.astro';
import ToolCard from '../components/ToolCard.astro';
---
<BaseLayout title="DivGaming Astro Staging | The Division 2 Community Hub" description="Astro staging build for DivGaming.com, an unofficial Division 2 community hub." canonical="/" noindex={true}>
  <section class="shell hero"><p class="eyebrow">Astro staging build</p><h1>DivGaming Command Center</h1><p class="lead">This is the safe Astro staging version of DivGaming. It is not the live DivGaming.com site yet. Phase 1 verifies the layout, routing, and GitHub Pages deployment pipeline.</p><div class="hero-actions"><a class="button" href={`${import.meta.env.BASE_URL}division-2/`}>Open Division 2 Hub</a><a class="button button--ghost" href={`${import.meta.env.BASE_URL}division-2/tools/`}>Open Tools</a></div></section>
  <section class="shell section"><p class="eyebrow">What do you need right now?</p><h2>Core paths</h2><div class="grid grid-4"><ToolCard title="Builds" description="Browse Division 2 builds and loadout resources." href="/division-2/builds/"/><ToolCard title="Tools" description="Open databases, trackers, and planning references." href="/division-2/tools/"/><ToolCard title="Guides" description="Find farming, systems, raid, and incursion help." href="/division-2/guides/"/><ToolCard title="Creators" description="Discover Division 2 community creators." href="/division-2/creators/"/></div></section>
  <section class="shell section"><p class="eyebrow">Division 2 Field Tools</p><h2>Important reference pages</h2><div class="grid grid-3"><ToolCard title="Named Items Database" description="Search named gear and weapons by slot, brand, core, talent, and attributes." href="/division-2/tools/named-items-database/" label="Open database"/><ToolCard title="Exotic Source Tracker" description="Find exotic weapons and gear by source, item type, and farming notes." href="/division-2/tools/exotic-source-tracker/" label="Open tracker"/><ToolCard title="Brand Set Database" description="Compare brand bonuses and plan builds around the stats you need." href="/division-2/tools/brand-set-database/" label="Open database"/><ToolCard title="Gearset Matrix" description="Review gear sets, bonuses, playstyles, and build direction." href="/division-2/tools/gearset-matrix/" label="Open matrix"/><ToolCard title="Gear Talents" description="Browse chest and backpack talents for build planning." href="/division-2/tools/gear-talents/" label="Open talents"/><ToolCard title="Weapon Talents" description="Review weapon talents and pair them with the right loadout." href="/division-2/tools/weapon-talents/" label="Open talents"/></div></section>
</BaseLayout>
