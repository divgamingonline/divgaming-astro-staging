---
import BaseLayout from '../layouts/BaseLayout.astro';
import buildsData from '../../data/builds.json';
import exoticsData from '../../data/division-2/exotics.json';
import namedItemsData from '../../data/division-2/named-items.json';
import brandsetsData from '../../data/division-2/brandsets.json';
import { getBuildVideos } from '../utils/builds';
import { normalizeItems } from '../utils/division2Tools';
import { getCreators } from '../utils/creators';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const videos = getBuildVideos(buildsData, 'all');
const creatorCount = getCreators(buildsData).length;
const exoticCount = normalizeItems(exoticsData).length;
const namedCount = normalizeItems(namedItemsData).length;
const brandCount = normalizeItems(brandsetsData).length;

const routes = [
  { eyebrow: 'Builds', title: 'Build Library', href: '/division-2/builds/', text: 'Browse Striker, PvE, solo, and PvP build routes from creator videos.', metric: videos.length },
  { eyebrow: 'Tools', title: 'Agent Tools', href: '/division-2/tools/', text: 'Use DivGaming databases for exotics, named items, brands, gear sets, and talents.', metric: exoticCount + namedCount + brandCount },
  { eyebrow: 'Creators', title: 'Creator Index', href: '/division-2/creators/', text: 'Discover Division 2 creators and route viewers directly to their YouTube videos.', metric: creatorCount },
  { eyebrow: 'Guides', title: 'Guide Library', href: '/division-2/guides/', text: 'A clean structure for farming, progression, endgame, raids, incursions, and tools.', metric: 'New' }
];
---

<BaseLayout
  title="DivGaming | Division 2 Builds, Tools, Guides, and Creator Videos"
  description="DivGaming is an unofficial Division 2 community hub for builds, tools, guides, creator videos, exotics, named items, and gear databases."
  canonical="/"
  noindex={true}
>
  <section class="shell hero">
    <div class="command-hero">
      <div>
        <p class="eyebrow">DivGaming.com Astro Staging</p>
        <h1>Division 2 command hub.</h1>
        <p class="lead">
          Builds, creator discovery, exotic sources, named items, brand sets,
          gear sets, talent references, and guide routes — rebuilt into one fast
          DivGaming experience.
        </p>

        <div class="hero-actions">
          <a class="button" href={`${base}/division-2/`}>Enter Division 2 Hub</a>
          <a class="button button--ghost" href={`${base}/division-2/tools/`}>Open Agent Tools</a>
        </div>
      </div>

      <aside class="command-panel">
        <p class="eyebrow">Live staging data</p>
        <div class="command-panel__list">
          <div class="command-panel__row"><span>Build videos</span><strong>{videos.length}</strong></div>
          <div class="command-panel__row"><span>Creators</span><strong>{creatorCount}</strong></div>
          <div class="command-panel__row"><span>Exotics</span><strong>{exoticCount}</strong></div>
          <div class="command-panel__row"><span>Named items</span><strong>{namedCount}</strong></div>
        </div>
      </aside>
    </div>
  </section>

  <section class="shell section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Main routes</p>
        <h2>Pick your lane</h2>
      </div>
      <p>
        This consolidated staging pass makes DivGaming feel like one connected
        site instead of separate prototype pages.
      </p>
    </div>

    <div class="grid quick-grid">
      {routes.map((route) => (
        <a class="card intent-card" href={`${base}${route.href}`}>
          <span class="tool-card__count">{route.metric}</span>
          <p class="eyebrow">{route.eyebrow}</p>
          <h2>{route.title}</h2>
          <p>{route.text}</p>
          <strong>Open route →</strong>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
