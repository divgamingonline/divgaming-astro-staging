---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const guides = [
  {
    title: 'Getting Back Into Division 2',
    status: 'Returning Players',
    text: 'A route for players coming back after a break who need to understand what to do first.',
    href: '/division-2/tools/'
  },
  {
    title: 'Exotic Farming',
    status: 'Farming',
    text: 'Find exotic items and use the tracker to understand where they come from.',
    href: '/division-2/tools/exotic-source-tracker/'
  },
  {
    title: 'Named Item Farming',
    status: 'Farming',
    text: 'Use named item references to understand sources, slots, talents, and target loot paths.',
    href: '/division-2/tools/named-items-database/'
  },
  {
    title: 'Build Basics',
    status: 'Buildcraft',
    text: 'Understand cores, talents, brand sets, gearsets, damage, armor, and skill choices.',
    href: '/division-2/builds/'
  },
  {
    title: 'Raids and Incursions',
    status: 'Endgame',
    text: 'Prepare for group content with roles, build lanes, and encounter planning.',
    href: '/division-2/builds/pve/'
  },
  {
    title: 'Countdown and Endgame Farming',
    status: 'Endgame',
    text: 'Improve your gear faster with better farming and optimization routes.',
    href: '/division-2/builds/pve/'
  }
];
---

<BaseLayout
  title="Division 2 Guides | DivGaming"
  description="Guide routes for Division 2 farming, builds, endgame, exotics, named items, raids, incursions, and returning players."
  canonical="/division-2/guides/"
  noindex={true}
>
  <section class="shell hero">
    <div class="command-hero">
      <div>
        <p class="eyebrow">Guides</p>
        <h1>Helpful paths for different player needs</h1>
        <p class="lead">
          Use these guide routes to find the right tool, build category, or
          reference page based on what you are trying to do.
        </p>
        <div class="hero-actions">
          <a class="btn primary" href={`${base}/division-2/tools/`}>Use Tools</a>
          <a class="btn ghost" href={`${base}/division-2/builds/`}>Find Builds</a>
        </div>
      </div>

      <aside class="command-panel">
        <p class="eyebrow">Guide routes</p>
        <div class="command-panel__list">
          <div class="command-panel__row"><span>Guide tracks</span><strong>{guides.length}</strong></div>
          <div class="command-panel__row"><span>Linked to tools</span><strong>Yes</strong></div>
        </div>
      </aside>
    </div>
  </section>

  <section class="shell section">
    <div class="section-head">
      <p class="eyebrow">Guide tracks</p>
      <h2>Choose what you are trying to do</h2>
      <p>
        These cards point you to useful pages while full guide articles are built out.
      </p>
    </div>

    <div class="guide-grid">
      {guides.map((guide) => (
        <a class="guide-card" href={`${base}${guide.href}`}>
          <span class="mission-kicker">{guide.status}</span>
          <strong>{guide.title}</strong>
          <p>{guide.text}</p>
          <em>Open related page →</em>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
