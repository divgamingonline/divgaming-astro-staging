---
import BaseLayout from '../../../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const guides = [
  ['Getting Back Into Division 2', 'Returning Players', 'A route for players coming back after a break who need to understand what to do first.', '/division-2/tools/'],
  ['Exotic Farming', 'Farming', 'Find exotic items and use the tracker to understand where they come from.', '/division-2/tools/exotic-source-tracker/'],
  ['Named Item Farming', 'Farming', 'Use named item references to understand sources, slots, talents, and target loot paths.', '/division-2/tools/named-items-database/'],
  ['Build Basics', 'Buildcraft', 'Understand cores, talents, brand sets, gearsets, damage, armor, and skill choices.', '/division-2/builds/'],
  ['Raids and Incursions', 'Endgame', 'Prepare for group content with roles, build lanes, and encounter planning.', '/division-2/builds/pve/'],
  ['Countdown and Endgame Farming', 'Endgame', 'Improve your gear faster with better farming and optimization routes.', '/division-2/builds/pve/']
];
---

<BaseLayout title="Division 2 Guides | DivGaming" canonical="/division-2/guides/">
  <section class="shell hero compact-hero">
    <div class="page-hero">
      <div>
        <p class="eyebrow">Guides</p>
        <h1>Helpful paths for different player needs</h1>
        <p class="lead">Use these guide routes to find the right tool, build category, or reference page based on what you are trying to do.</p>
      </div>
      <aside class="hero-panel">
        <span>Guide Tracks</span>
        <strong>{guides.length}</strong>
        <small>Starting points</small>
      </aside>
    </div>
  </section>

  <section class="shell section">
    <div class="feature-grid">
      {guides.map(([title, status, text, href]) => (
        <a class="feature-card" href={`${base}${href}`}>
          <span>{status}</span>
          <strong>{title}</strong>
          <p>{text}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
