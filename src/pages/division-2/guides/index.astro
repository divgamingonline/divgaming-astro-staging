---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const guides = [
  {
    title: 'Getting Back Into Division 2',
    status: 'Returning Agents',
    text: 'A returning-agent path for gear, seasons, expertise, SHD levels, and endgame priorities.',
    href: '/division-2/tools/'
  },
  {
    title: 'Exotic Farming',
    status: 'Farming',
    text: 'Find exotic sources and connect directly into the Exotic Source Tracker.',
    href: '/division-2/tools/exotic-source-tracker/'
  },
  {
    title: 'Named Item Farming',
    status: 'Farming',
    text: 'Use named item references to understand sources, slots, talents, and target loot paths.',
    href: '/division-2/tools/named-items-database/'
  },
  {
    title: 'Build Basics',
    status: 'Buildcraft',
    text: 'Understand damage, armor, skills, crit, cores, talents, and gear synergy.',
    href: '/division-2/builds/'
  },
  {
    title: 'Raids and Incursions',
    status: 'Endgame',
    text: 'Prepare for endgame group content with roles, build lanes, and encounter planning.',
    href: '/division-2/builds/pve/'
  },
  {
    title: 'Countdown and Endgame Farming',
    status: 'Endgame',
    text: 'Improve gear quickly with efficient farming and optimization routes.',
    href: '/division-2/builds/pve/'
  }
];
---

<BaseLayout
  title="Division 2 Guides | DivGaming"
  description="Guide structure for Division 2 farming, builds, endgame, exotics, named items, raids, incursions, and returning agents."
  canonical="/division-2/guides/"
  noindex={true}
>
  <section class="shell hero">
    <div class="command-hero">
      <div>
        <p class="eyebrow">Guide Library</p>
        <h1>Guides with a real path.</h1>
        <p class="lead">
          Farming, returning-agent help, build basics, endgame prep, and tool-linked
          references for Division 2 players.
        </p>
        <div class="hero-actions">
          <a class="button" href={`${base}/division-2/tools/`}>Use Tools</a>
          <a class="button button--ghost" href={`${base}/division-2/builds/`}>Find Builds</a>
        </div>
      </div>

      <aside class="command-panel">
        <p class="eyebrow">Guide routes</p>
        <div class="command-panel__list">
          <div class="command-panel__row"><span>Guide tracks</span><strong>{guides.length}</strong></div>
          <div class="command-panel__row"><span>Linked to tools</span><strong>Yes</strong></div>
        </div>
      </aside>
    </div>
  </section>

  <section class="shell section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Guide tracks</p>
        <h2>Content lanes</h2>
      </div>
      <p>
        Each guide card points agents toward an existing DivGaming route while
        full article pages are built out.
      </p>
    </div>

    <div class="grid guide-grid">
      {guides.map((guide) => (
        <a class="card guide-card" href={`${base}${guide.href}`}>
          <p class="eyebrow">{guide.status}</p>
          <h2>{guide.title}</h2>
          <p>{guide.text}</p>
          <strong>Open related route →</strong>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
