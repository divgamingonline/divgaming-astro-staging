---
import BaseLayout from '../../layouts/BaseLayout.astro';
import buildsData from '../../../data/builds.json';
import exoticsData from '../../../data/division-2/exotics.json';
import namedItemsData from '../../../data/division-2/named-items.json';
import { getBuildVideos } from '../../utils/builds';
import { normalizeItems } from '../../utils/division2Tools';
import { getCreators } from '../../utils/creators';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const videos = getBuildVideos(buildsData, 'all');
const creators = getCreators(buildsData);
const exotics = normalizeItems(exoticsData);
const namedItems = normalizeItems(namedItemsData);

const routes = [
  { title: 'Build Library', href: '/division-2/builds/', count: videos.length, text: 'Striker, PvE, solo, PvP, and full build discovery.' },
  { title: 'Agent Backpack', href: '/division-2/tools/', count: exotics.length + namedItems.length, text: 'Exotics, named items, brands, gearsets, and talent databases.' },
  { title: 'Video Intel', href: '/division-2/videos/', count: videos.length, text: 'Creator-first video discovery with direct YouTube routing.' },
  { title: 'Creator Network', href: '/division-2/creators/', count: creators.length, text: 'A clean directory for Division 2 creators represented in the library.' },
  { title: 'Guide Routes', href: '/division-2/guides/', count: 'SHD', text: 'Guide structure for farming, progression, raids, incursions, and endgame.' }
];
---

<BaseLayout
  title="Division 2 Hub | DivGaming"
  description="The DivGaming Division 2 hub connects builds, tools, videos, creators, and guide routes."
  canonical="/division-2/"
  noindex={true}
>
  <section class="shell hero">
    <div class="command-hero">
      <div>
        <p class="eyebrow">Division 2 Hub</p>
        <h1>SHD Intel Routes</h1>
        <p class="lead">
          Fast routes into builds, tools, videos, creators, and guides. This is
          the central Division 2 landing page for DivGaming.
        </p>

        <div class="hero-actions">
          <a class="btn primary" href={`${base}/division-2/builds/`}>Find Builds</a>
          <a class="btn ghost" href={`${base}/division-2/tools/`}>Open Tools</a>
        </div>
      </div>

      <aside class="command-panel">
        <p class="eyebrow">Available now</p>
        <div class="command-panel__list">
          <div class="command-panel__row"><span>Build videos</span><strong>{videos.length}</strong></div>
          <div class="command-panel__row"><span>Creators</span><strong>{creators.length}</strong></div>
          <div class="command-panel__row"><span>Exotics</span><strong>{exotics.length}</strong></div>
          <div class="command-panel__row"><span>Named items</span><strong>{namedItems.length}</strong></div>
        </div>
      </aside>
    </div>
  </section>

  <section class="shell section">
    <div class="section-head">
      <p class="eyebrow">Route map</p>
      <h2>Where agents go</h2>
      <p>
        Builds, tools, creators, videos, and guide paths now share the same
        DivGaming production-style interface.
      </p>
    </div>

    <div class="tools-grid">
      {routes.map((route) => (
        <a class="tool-card" href={`${base}${route.href}`}>
          <span class="tool-card__count">{route.count}</span>
          <span class="mission-kicker">Division 2</span>
          <strong>{route.title}</strong>
          <p>{route.text}</p>
          <em>Open route →</em>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
