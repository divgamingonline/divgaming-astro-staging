---
import BaseLayout from '../../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const sections = [
  ['Build Library', '/division-2/builds/', 'Browse build and creator videos by playstyle, activity, and category.'],
  ['Gear Tools', '/division-2/tools/', 'Research exotics, named items, brand sets, gearsets, and talents.'],
  ['Saved Builds', '/division-2/saved/', 'Open builds you saved for later reference on this device.'],
  ['Video Library', '/division-2/videos/', 'Find creator videos and open the original YouTube videos directly.'],
  ['Creator Directory', '/division-2/creators/', 'Browse creators represented in the DivGaming video library.'],
  ['Guides', '/division-2/guides/', 'Use guide paths for farming, builds, returning players, and endgame.']
];
---

<BaseLayout title="Division 2 Hub | DivGaming" canonical="/division-2/">
  <section class="shell hero compact-hero">
    <div class="page-hero">
      <div>
        <p class="eyebrow">Division 2 Hub</p>
        <h1>Choose a section</h1>
        <p class="lead">Use this page as the main starting point for builds, gear tools, videos, creators, saved builds, and guides.</p>
      </div>
      <aside class="hero-panel">
        <span>Status</span>
        <strong>Active</strong>
        <small>Production-parity reset</small>
      </aside>
    </div>
  </section>

  <section class="shell section">
    <div class="section-head">
      <p class="eyebrow">Site sections</p>
      <h2>Start with what you need</h2>
      <p>These sections are organized around common player needs.</p>
    </div>
    <div class="feature-grid">
      {sections.map(([title, href, text]) => (
        <a class="feature-card" href={`${base}${href}`}>
          <span>Division 2</span>
          <strong>{title}</strong>
          <p>{text}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
