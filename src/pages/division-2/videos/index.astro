---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import BuildGrid from '../../../components/BuildGrid.astro';
import buildsData from '../../../../data/builds.json';
import { getBuildVideos } from '../../../utils/builds';

const videos = getBuildVideos(buildsData, 'all');
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout
  title="Division 2 Video Library | DivGaming"
  description="Browse Division 2 creator videos indexed by DivGaming and open the original videos directly on YouTube."
  canonical="/division-2/videos/"
  noindex={true}
>
  <section class="shell hero">
    <div class="command-hero">
      <div>
        <p class="eyebrow">Creator Videos</p>
        <h1>Find videos without taking views from creators</h1>
        <p class="lead">
          DivGaming indexes videos to make them easier to find. Watching happens
          directly on YouTube so creators keep their views, recommendations, and monetization.
        </p>
        <div class="hero-actions">
          <a class="btn primary" href={`${base}/division-2/builds/`}>Build Categories</a>
          <a class="btn ghost" href={`${base}/division-2/creators/`}>Creators</a>
        </div>
      </div>

      <aside class="command-panel">
        <p class="eyebrow">Video index</p>
        <div class="command-panel__list">
          <div class="command-panel__row"><span>Indexed videos</span><strong>{videos.length}</strong></div>
          <div class="command-panel__row"><span>Embeds</span><strong>None</strong></div>
          <div class="command-panel__row"><span>Playback</span><strong>YouTube</strong></div>
        </div>
      </aside>
    </div>
  </section>

  <section class="shell section">
    <div class="section-head">
      <p class="eyebrow">Video Library</p>
      <h2>{videos.length} indexed videos</h2>
      <p>
        Search by creator, build name, tag, activity, or keyword.
      </p>
    </div>

    <BuildGrid videos={videos} />
  </section>
</BaseLayout>
