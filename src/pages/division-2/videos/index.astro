---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import BuildGrid from '../../../components/BuildGrid.astro';
import buildsData from '../../../../data/builds.json';
import { getBuildVideos } from '../../../utils/builds';

const videos = getBuildVideos(buildsData, 'all');
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout
  title="Division 2 Video Library | DivGaming Astro Staging"
  description="Browse DivGaming Division 2 creator videos and open them directly on YouTube."
  canonical="/division-2/videos/"
  noindex={true}
>
  <section class="shell hero">
    <div class="hub-hero">
      <p class="eyebrow">Creator Video Discovery</p>
      <h1>Find a build, then support the creator.</h1>
      <p class="lead">
        DivGaming indexes build videos for discovery, but no videos are embedded.
        All watch actions open YouTube directly.
      </p>
      <div class="hero-actions">
        <a class="button" href={`${base}/division-2/builds/`}>Build categories</a>
        <a class="button button--ghost" href={`${base}/division-2/`}>Division 2 hub</a>
      </div>
    </div>
  </section>

  <section class="shell section">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Video Library</p>
        <h2>{videos.length} indexed videos</h2>
      </div>
      <p>
        Search by creator, build name, tag, activity, or keyword. This is the
        Astro staging version of DivGaming video discovery.
      </p>
    </div>

    <BuildGrid videos={videos} />
  </section>
</BaseLayout>
