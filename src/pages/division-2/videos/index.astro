---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import VideoGrid from '../../../components/VideoGrid.astro';
import buildsData from '../../../../data/builds.json';
---

<BaseLayout title="Division 2 Video Library | DivGaming" canonical="/division-2/videos/">
  <section class="shell hero compact-hero">
    <div class="page-hero">
      <div>
        <p class="eyebrow">Creator Videos</p>
        <h1>Find videos without taking views from creators</h1>
        <p class="lead">DivGaming indexes videos to make them easier to find. Watching happens directly on YouTube.</p>
      </div>
      <aside class="hero-panel">
        <span>Embeds</span>
        <strong>None</strong>
        <small>Creator-first routing</small>
      </aside>
    </div>
  </section>
  <VideoGrid data={buildsData} category="all" />
</BaseLayout>
