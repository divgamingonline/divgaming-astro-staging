---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import buildsData from '../../../../data/builds.json';
import {
  normalizeBuilds,
  videoSlug,
  youtubeThumbnail,
  videoDescription,
  videoCategory,
  videoTags,
  formatDate
} from '../../../utils/builds';

export async function getStaticPaths() {
  const allVideos = normalizeBuilds(buildsData)
    .filter((video) => video.title && (video.id || video.videoId));

  const seen = new Set();

  return allVideos
    .map((video) => {
      const slug = videoSlug(video);
      return { slug, video };
    })
    .filter(({ slug }) => {
      if (seen.has(slug)) return false;
      seen.add(slug);
      return true;
    })
    .map(({ slug, video }) => ({
      params: { slug },
      props: { video }
    }));
}

const { video } = Astro.props;

const slug = videoSlug(video);
const canonical = `/division-2/videos/${slug}/`;
const description = videoDescription(video);
const thumbnail = youtubeThumbnail(video);
const youtubeUrl = video.url || (
  video.videoId
    ? `https://www.youtube.com/watch?v=${encodeURIComponent(video.videoId)}`
    : 'https://www.youtube.com/'
);
const category = videoCategory(video);
const tags = videoTags(video);
const publishedDate = formatDate(video.publishedAt);

const title = `${video.title || 'Division 2 Video'} | DivGaming`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'VideoObject',
  name: video.title || 'Division 2 Video',
  description,
  thumbnailUrl: thumbnail ? [thumbnail] : undefined,
  uploadDate: video.publishedAt,
  url: youtubeUrl,
  contentUrl: youtubeUrl,
  publisher: {
    '@type': 'Organization',
    name: video.creator || 'YouTube creator'
  }
};
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  image={thumbnail}
  noindex={true}
>
  <section class="shell video-layout">
    <article class="card video-page">
      <p class="eyebrow">Division 2 Creator Video</p>
      <h1>{video.title}</h1>

      <div class="video-meta">
        {video.creator && <span>Creator: {video.creator}</span>}
        {publishedDate && <span>Published: {publishedDate}</span>}
        {category && <span>Category: {category}</span>}
      </div>

      <a class="video-thumb-link" href={youtubeUrl} target="_blank" rel="noopener noreferrer">
        <img class="video-thumb" src={thumbnail} alt="" loading="eager" />
        <span class="youtube-overlay">Watch on YouTube →</span>
      </a>

      <p class="creator-note">
        DivGaming does not embed creator videos. Use the YouTube link below to
        watch directly on the creator’s channel and support their views,
        recommendations, and monetization.
      </p>

      <p class="lead">{description}</p>

      {tags.length > 0 && (
        <div class="tag-list" aria-label="Video tags">
          {tags.slice(0, 12).map((tag) => (
            <span>{tag}</span>
          ))}
        </div>
      )}

      <div class="video-actions">
        <a class="button" href={youtubeUrl} target="_blank" rel="noopener noreferrer">
          Watch on YouTube
        </a>

        <a class="button button--ghost" href={`${import.meta.env.BASE_URL}division-2/videos/`}>
          Back to video index
        </a>
      </div>
    </article>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <style>
    .video-layout {
      display: grid;
      gap: 22px;
    }

    .video-page {
      padding: 28px;
    }

    .video-page h1 {
      margin: 0 0 16px;
      font-size: clamp(2rem, 5vw, 4.25rem);
      line-height: 1;
      letter-spacing: -0.045em;
    }

    .video-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 18px;
      color: var(--dg-muted);
      font-size: 0.9rem;
    }

    .video-meta span {
      border: 1px solid rgba(255, 107, 0, 0.18);
      border-radius: 999px;
      padding: 5px 10px;
      background: rgba(255, 255, 255, 0.04);
    }

    .video-thumb-link {
      position: relative;
      display: block;
      overflow: hidden;
      border-radius: 18px;
      margin: 18px 0;
      border: 1px solid rgba(255, 107, 0, 0.22);
      background: #000;
    }

    .video-thumb-link:hover {
      text-decoration: none;
    }

    .video-thumb {
      display: block;
      width: 100%;
      max-height: 520px;
      object-fit: cover;
      transition: transform 180ms ease, opacity 180ms ease;
    }

    .video-thumb-link:hover .video-thumb {
      transform: scale(1.015);
      opacity: 0.76;
    }

    .youtube-overlay {
      position: absolute;
      left: 18px;
      bottom: 18px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 999px;
      padding: 10px 14px;
      background: var(--dg-orange);
      color: #141006;
      font-weight: 950;
      box-shadow: 0 14px 34px rgba(0, 0, 0, 0.35);
    }

    .creator-note {
      border: 1px solid rgba(255, 107, 0, 0.2);
      border-radius: 16px;
      padding: 14px 16px;
      color: var(--dg-muted);
      background: rgba(255, 107, 0, 0.08);
    }

    .tag-list {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 20px;
    }

    .tag-list span {
      border: 1px solid rgba(255, 107, 0, 0.22);
      border-radius: 999px;
      padding: 5px 10px;
      color: var(--dg-muted);
      background: rgba(255, 255, 255, 0.04);
      font-size: 0.82rem;
    }

    .video-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      margin-top: 24px;
    }
  </style>
</BaseLayout>
