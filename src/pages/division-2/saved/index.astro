---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---

<BaseLayout title="Saved Builds | DivGaming" canonical="/division-2/saved/">
  <section class="shell hero compact-hero">
    <div class="page-hero">
      <div>
        <p class="eyebrow">Saved Builds</p>
        <h1>Your saved build references</h1>
        <p class="lead">Builds saved on this device will appear here. This uses your browser storage and does not require an account.</p>
      </div>
      <aside class="hero-panel">
        <span>Storage</span>
        <strong>Local</strong>
        <small>This device only</small>
      </aside>
    </div>
  </section>

  <section class="shell section">
    <div id="saved-builds" class="saved-grid"></div>
  </section>

  <script>
    const root = document.getElementById('saved-builds');

    function getSaved() {
      try { return JSON.parse(localStorage.getItem('divgamingSavedBuilds') || '[]'); }
      catch { return []; }
    }

    function renderSaved() {
      const saved = getSaved();

      if (!saved.length) {
        root.innerHTML = `
          <div class="empty-state">
            <h2>No saved builds yet.</h2>
            <p>Go to the Build Library and tap Save on videos you want to reference later.</p>
            <a class="button primary" href="../builds/">Browse Builds</a>
          </div>
        `;
        return;
      }

      root.innerHTML = saved.map((item) => `
        <article class="video-card saved-card">
          <div class="video-body">
            <p class="eyebrow">${item.creator || 'Creator'}</p>
            <h3>${item.title || 'Saved build'}</h3>
            <div class="video-actions">
              <a class="button primary" href="${item.url}" target="_blank" rel="noopener">Watch on YouTube</a>
              <button class="button ghost" data-remove-saved="${item.url}">Remove</button>
            </div>
          </div>
        </article>
      `).join('');

      for (const button of root.querySelectorAll('[data-remove-saved]')) {
        button.addEventListener('click', () => {
          const next = getSaved().filter((item) => item.url !== button.dataset.removeSaved);
          localStorage.setItem('divgamingSavedBuilds', JSON.stringify(next));
          renderSaved();
        });
      }
    }

    renderSaved();
  </script>
</BaseLayout>
