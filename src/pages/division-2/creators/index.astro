---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import buildsData from '../../../../data/builds.json';
import { getVideos, videoCreator, videoUrl } from '../../../utils/videos';

const videos = getVideos(buildsData);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const creators = [...new Map(videos.map((video) => [videoCreator(video), video])).entries()]
  .map(([name, video]) => ({
    name,
    count: videos.filter((item) => videoCreator(item) === name).length,
    url: videoUrl(video)
  }))
  .sort((a, b) => b.count - a.count);
---

<BaseLayout title="Division 2 Creators | DivGaming" canonical="/division-2/creators/">
  <section class="shell hero compact-hero">
    <div class="page-hero">
      <div>
        <p class="eyebrow">Creators</p>
        <h1>Find Division 2 creators</h1>
        <p class="lead">Browse creators represented in the DivGaming video library and open their videos directly on YouTube.</p>
      </div>
      <aside class="hero-panel">
        <span>Creators</span>
        <strong>{creators.length}</strong>
        <small>Listed</small>
      </aside>
    </div>
  </section>

  <section class="shell section">
    <div class="creator-grid">
      {creators.map((creator) => (
        <article class="feature-card">
          <span>{creator.count} videos</span>
          <strong>{creator.name}</strong>
          <p>Creator videos indexed in the DivGaming library.</p>
          <a class="button ghost" href={`${base}/division-2/videos/`}>View Library</a>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
