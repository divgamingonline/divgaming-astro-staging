---
import ToolDatabasePage from '../../../../components/ToolDatabasePage.astro';
import brandsetsData from '../../../../../data/division-2/brandsets.json';
import { normalizeItems } from '../../../../utils/division2Tools';

const items = normalizeItems(brandsetsData);
const featuredItems = items.filter((item) =>
  ['Česká Výroba s.r.o.', 'Grupo Sombra S.A.', 'Providence Defense'].includes(String(item.displayName || item.name))
);
---

<ToolDatabasePage
  title="Brand Set Database"
  eyebrow="Brand Bonuses"
  description="Compare Division 2 brand set bonuses, default cores, build roles, and named item relationships."
  canonical="/division-2/tools/brand-set-database/"
  dataset={brandsetsData}
  featuredItems={featuredItems}
/>
