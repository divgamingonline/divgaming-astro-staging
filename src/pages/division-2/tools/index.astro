---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import exoticsData from '../../../../data/division-2/exotics.json';
import namedItemsData from '../../../../data/division-2/named-items.json';
import brandsetsData from '../../../../data/division-2/brandsets.json';
import gearsetsData from '../../../../data/division-2/gearsets.json';
import gearTalentsData from '../../../../data/division-2/gear-talents.json';
import weaponTalentsData from '../../../../data/division-2/weapon-talents.json';
import { getItems } from '../../../utils/tools';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const tools = [
  ['Exotic Source Tracker', '/division-2/tools/exotic-source-tracker/', getItems(exoticsData).length, 'Find exotic weapons and gear, sources, and talents.'],
  ['Named Items Database', '/division-2/tools/named-items-database/', getItems(namedItemsData).length, 'Look up named gear, named weapons, perfect talents, slots, and sources.'],
  ['Brand Set Database', '/division-2/tools/brand-set-database/', getItems(brandsetsData).length, 'Compare high-end brand set bonuses and roles.'],
  ['Gearset Matrix', '/division-2/tools/gearset-matrix/', getItems(gearsetsData).length, 'Review gearset bonuses, chest talents, backpack talents, and roles.'],
  ['Gear Talents', '/division-2/tools/gear-talents/', getItems(gearTalentsData).length, 'Search chest and backpack talents for build planning.'],
  ['Weapon Talents', '/division-2/tools/weapon-talents/', getItems(weaponTalentsData).length, 'Search weapon talents and understand build options.']
];
---

<BaseLayout title="Division 2 Tools | DivGaming" canonical="/division-2/tools/">
  <section class="shell hero compact-hero">
    <div class="page-hero">
      <div>
        <p class="eyebrow">Gear Tools</p>
        <h1>Research items and plan builds</h1>
        <p class="lead">Use these tools to look up items, compare gear options, understand talents, and make better build decisions.</p>
      </div>
      <aside class="hero-panel">
        <span>Tools</span>
        <strong>{tools.length}</strong>
        <small>Databases</small>
      </aside>
    </div>
  </section>

  <section class="shell section">
    <div class="feature-grid">
      {tools.map(([title, href, count, text]) => (
        <a class="feature-card" href={`${base}${href}`}>
          <span>{count} records</span>
          <strong>{title}</strong>
          <p>{text}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
