---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import exoticsData from '../../../../data/division-2/exotics.json';
import namedItemsData from '../../../../data/division-2/named-items.json';
import brandsetsData from '../../../../data/division-2/brandsets.json';
import gearsetsData from '../../../../data/division-2/gearsets.json';
import gearTalentsData from '../../../../data/division-2/gear-talents.json';
import weaponTalentsData from '../../../../data/division-2/weapon-talents.json';
import { normalizeItems } from '../../../utils/division2Tools';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const tools = [
  {
    title: 'Exotic Source Tracker',
    href: '/division-2/tools/exotic-source-tracker/',
    count: normalizeItems(exoticsData).length,
    description: 'Track exotic gear and weapon sources, talents, cores, and farming notes.'
  },
  {
    title: 'Named Items Database',
    href: '/division-2/tools/named-items-database/',
    count: normalizeItems(namedItemsData).length,
    description: 'Browse named high-end gear and weapons with talents, brands, slots, and source notes.'
  },
  {
    title: 'Brand Set Database',
    href: '/division-2/tools/brand-set-database/',
    count: normalizeItems(brandsetsData).length,
    description: 'Review brand set bonuses, roles, cores, and named item relationships.'
  },
  {
    title: 'Gearset Matrix',
    href: '/division-2/tools/gearset-matrix/',
    count: normalizeItems(gearsetsData).length,
    description: 'Compare gear set bonuses, chest effects, backpack effects, and build roles.'
  },
  {
    title: 'Gear Talents',
    href: '/division-2/tools/gear-talents/',
    count: normalizeItems(gearTalentsData).length,
    description: 'Reference backpack and chest talents, including perfect talent relationships.'
  },
  {
    title: 'Weapon Talents',
    href: '/division-2/tools/weapon-talents/',
    count: normalizeItems(weaponTalentsData).length,
    description: 'Reference weapon talents and perfect weapon talent variants.'
  }
];
---

<BaseLayout
  title="Division 2 Tools | DivGaming Astro Staging"
  description="Division 2 databases and reference tools for DivGaming."
  canonical="/division-2/tools/"
  noindex={true}
>
  <section class="shell tools-index-hero">
    <p class="eyebrow">Division 2 Field Tools</p>
    <h1>Databases built for agents</h1>
    <p class="lead">
      This is the Astro staging version of the DivGaming tools section. These
      pages now load real curated Division 2 data instead of placeholder content.
    </p>
  </section>

  <section class="shell section">
    <div class="grid tools-grid">
      {tools.map((tool) => (
        <a class="card tool-card" href={`${base}${tool.href}`}>
          <span class="tool-card__count">{tool.count}</span>
          <p class="eyebrow">Reference tool</p>
          <h2>{tool.title}</h2>
          <p>{tool.description}</p>
          <strong>Open tool →</strong>
        </a>
      ))}
    </div>
  </section>

  <style>
    .tools-index-hero {
      border: 1px solid rgba(255, 107, 0, 0.16);
      border-radius: 28px;
      margin-top: 40px;
      padding: clamp(24px, 5vw, 54px);
      background:
        radial-gradient(circle at top left, rgba(255, 107, 0, 0.24), transparent 42%),
        linear-gradient(140deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.025));
      box-shadow: var(--dg-shadow);
    }

    .tools-index-hero h1 {
      margin: 0;
      max-width: 900px;
      font-size: clamp(2.5rem, 8vw, 6rem);
      line-height: 0.9;
      letter-spacing: -0.065em;
      text-transform: uppercase;
    }

    .tools-grid {
      grid-template-columns: repeat(auto-fit, minmax(285px, 1fr));
      align-items: stretch;
    }

    .tool-card {
      position: relative;
      min-height: 245px;
      padding: 22px;
      overflow: hidden;
      text-decoration: none;
    }

    .tool-card:hover {
      transform: translateY(-2px);
      border-color: rgba(255, 107, 0, 0.42);
      text-decoration: none;
    }

    .tool-card h2 {
      margin: 0 0 10px;
      font-size: 1.55rem;
      letter-spacing: -0.035em;
    }

    .tool-card p:not(.eyebrow) {
      color: var(--dg-muted);
    }

    .tool-card strong {
      color: var(--dg-orange);
      margin-top: auto;
    }

    .tool-card__count {
      position: absolute;
      right: 18px;
      top: 12px;
      color: rgba(255, 107, 0, 0.18);
      font-size: 5rem;
      font-weight: 950;
      line-height: 1;
      letter-spacing: -0.08em;
    }
  </style>
</BaseLayout>
