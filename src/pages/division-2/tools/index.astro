---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import exoticsData from '../../../../data/division-2/exotics.json';
import namedItemsData from '../../../../data/division-2/named-items.json';
import brandsetsData from '../../../../data/division-2/brandsets.json';
import gearsetsData from '../../../../data/division-2/gearsets.json';
import gearTalentsData from '../../../../data/division-2/gear-talents.json';
import weaponTalentsData from '../../../../data/division-2/weapon-talents.json';
import { normalizeItems } from '../../../utils/division2Tools';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const tools = [
  {
    title: 'Exotic Source Tracker',
    href: '/division-2/tools/exotic-source-tracker/',
    count: normalizeItems(exoticsData).length,
    text: 'Find exotic weapons and gear, where they come from, and what their talents do.'
  },
  {
    title: 'Named Items Database',
    href: '/division-2/tools/named-items-database/',
    count: normalizeItems(namedItemsData).length,
    text: 'Look up named weapons and gear, perfect talents, slots, sources, and item details.'
  },
  {
    title: 'Brand Set Database',
    href: '/division-2/tools/brand-set-database/',
    count: normalizeItems(brandsetsData).length,
    text: 'Compare high-end brand set bonuses and understand what each brand supports.'
  },
  {
    title: 'Gearset Matrix',
    href: '/division-2/tools/gearset-matrix/',
    count: normalizeItems(gearsetsData).length,
    text: 'Review gearset bonuses, chest/backpack talents, and what each set is built for.'
  },
  {
    title: 'Gear Talents',
    href: '/division-2/tools/gear-talents/',
    count: normalizeItems(gearTalentsData).length,
    text: 'Search chest and backpack talents for build planning.'
  },
  {
    title: 'Weapon Talents',
    href: '/division-2/tools/weapon-talents/',
    count: normalizeItems(weaponTalentsData).length,
    text: 'Search weapon talents and understand what works with your weapon type.'
  }
];
---

<BaseLayout
  title="Division 2 Tools | DivGaming"
  description="Use DivGaming Division 2 tools to research exotics, named items, brand sets, gearsets, gear talents, and weapon talents."
  canonical="/division-2/tools/"
  noindex={true}
>
  <section class="shell hero">
    <div class="command-hero">
      <div>
        <p class="eyebrow">Gear Tools</p>
        <h1>Research items and plan builds</h1>
        <p class="lead">
          Use these tools to look up items, compare gear options, understand talents,
          and make better build decisions.
        </p>
        <div class="hero-actions">
          <a class="btn primary" href={`${base}/division-2/tools/exotic-source-tracker/`}>Exotics</a>
          <a class="btn ghost" href={`${base}/division-2/tools/named-items-database/`}>Named Items</a>
        </div>
      </div>

      <aside class="command-panel">
        <p class="eyebrow">Tool records</p>
        <div class="command-panel__list">
          {tools.slice(0, 4).map((tool) => (
            <div class="command-panel__row"><span>{tool.title}</span><strong>{tool.count}</strong></div>
          ))}
        </div>
      </aside>
    </div>
  </section>

  <section class="shell section">
    <div class="section-head">
      <p class="eyebrow">Available tools</p>
      <h2>Choose a database</h2>
      <p>
        Each database is searchable and filterable, so you can quickly find the
        gear, item, or talent you are looking for.
      </p>
    </div>

    <div class="tools-grid">
      {tools.map((tool) => (
        <a class="tool-card" href={`${base}${tool.href}`}>
          <span class="tool-card__count">{tool.count}</span>
          <span class="mission-kicker">Tool</span>
          <strong>{tool.title}</strong>
          <p>{tool.text}</p>
          <em>Open tool →</em>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
