---
import ToolDatabasePage from '../../../../components/ToolDatabasePage.astro';
import namedItemsData from '../../../../../data/division-2/named-items.json';
import { normalizeItems } from '../../../../utils/division2Tools';

const items = normalizeItems(namedItemsData);
const featuredItems = items.filter((item) =>
  ['The Gift', 'Matador', 'Turmoil'].includes(String(item.displayName || item.name))
);
---

<ToolDatabasePage
  title="Named Items Database"
  eyebrow="Named Gear and Weapons"
  description="Browse Division 2 named items, including brands, slots, talents, attributes, core behavior, and source notes."
  canonical="/division-2/tools/named-items-database/"
  dataset={namedItemsData}
  featuredItems={featuredItems}
/>
