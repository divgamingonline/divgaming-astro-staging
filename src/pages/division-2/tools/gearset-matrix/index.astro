---
import ToolDatabasePage from '../../../../components/ToolDatabasePage.astro';
import gearsetsData from '../../../../../data/division-2/gearsets.json';
import { normalizeItems } from '../../../../utils/division2Tools';

const items = normalizeItems(gearsetsData);
const featuredItems = items.filter((item) =>
  ['Striker’s Battlegear', 'Heartbreaker', 'Hunter’s Fury'].includes(String(item.displayName || item.name))
);
---

<ToolDatabasePage
  title="Gearset Matrix"
  eyebrow="Gear Set Comparison"
  description="Compare Division 2 gear sets, bonuses, backpack effects, chest effects, default cores, and intended build roles."
  canonical="/division-2/tools/gearset-matrix/"
  dataset={gearsetsData}
  featuredItems={featuredItems}
/>
