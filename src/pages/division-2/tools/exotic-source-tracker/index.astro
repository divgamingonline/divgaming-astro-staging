---
import ToolDatabasePage from '../../../../components/ToolDatabasePage.astro';
import exoticsData from '../../../../../data/division-2/exotics.json';
import { normalizeItems } from '../../../../utils/division2Tools';

const items = normalizeItems(exoticsData);
const featuredItems = items.filter((item) =>
  ['Ouroboros', 'St. Elmo’s Engine', 'Eagle Bearer'].includes(String(item.displayName || item.name))
);
---

<ToolDatabasePage
  title="Exotic Source Tracker"
  eyebrow="Exotic Farming"
  description="Track Division 2 exotic sources, item types, talents, default cores, and farming notes."
  canonical="/division-2/tools/exotic-source-tracker/"
  dataset={exoticsData}
  featuredItems={featuredItems}
/>
