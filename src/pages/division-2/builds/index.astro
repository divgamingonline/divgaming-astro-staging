---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import BuildGrid from '../../../components/BuildGrid.astro';
import buildsData from '../../../../data/builds.json';
import { getBuildVideos } from '../../../utils/builds';

const videos = getBuildVideos(buildsData, 'all');
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout
  title="Division 2 Builds | DivGaming"
  description="Browse Division 2 build videos by creator, playstyle, activity, and category."
  canonical="/division-2/builds/"
  noindex={true}
>
  <section class="shell hero">
    <div class="command-hero">
      <div>
        <p class="eyebrow">Build Library</p>
        <h1>Find a build that fits your playstyle</h1>
        <p class="lead">
          Browse creator build videos for PvE, PvP, solo play, Striker, farming,
          and endgame activities. Videos open on YouTube so creators keep the view.
        </p>
        <div class="hero-actions">
          <a class="btn primary" href={`${base}/division-2/builds/striker/`}>Striker Builds</a>
          <a class="btn ghost" href={`${base}/division-2/videos/`}>Video Library</a>
        </div>
      </div>

      <aside class="command-panel">
        <p class="eyebrow">Build index</p>
        <div class="command-panel__list">
          <div class="command-panel__row"><span>Indexed videos</span><strong>{videos.length}</strong></div>
          <div class="command-panel__row"><span>Watch location</span><strong>YouTube</strong></div>
        </div>
      </aside>
    </div>
  </section>

  <section class="shell section">
    <div class="section-head">
      <p class="eyebrow">Search builds</p>
      <h2>{videos.length} build videos</h2>
      <p>
        Search by title, creator, build type, activity, or tag. Use the filters
        to narrow the list without leaving the page.
      </p>
    </div>

    <BuildGrid videos={videos} />
  </section>
</BaseLayout>
