---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import VideoGrid from '../../../components/VideoGrid.astro';
import buildsData from '../../../../data/builds.json';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="Division 2 Builds | DivGaming" canonical="/division-2/builds/">
  <section class="shell hero compact-hero">
    <div class="page-hero">
      <div>
        <p class="eyebrow">Build Library</p>
        <h1>Find a build that fits your playstyle</h1>
        <p class="lead">Browse creator build videos for PvE, PvP, solo play, Striker, farming, and endgame activities. Save builds for later reference.</p>
        <div class="hero-actions">
          <a class="button primary" href={`${base}/division-2/saved/`}>Saved Builds</a>
          <a class="button ghost" href={`${base}/division-2/builds/striker/`}>Striker Builds</a>
        </div>
      </div>
      <aside class="hero-panel">
        <span>Playback</span>
        <strong>YouTube</strong>
        <small>Creator-first links</small>
      </aside>
    </div>
  </section>
  <VideoGrid data={buildsData} category="all" />
</BaseLayout>
